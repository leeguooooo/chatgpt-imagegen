def _chrome_user_data_dirs() -> list[Path]:
    home = Path.home()
    return [
        home / "Library" / "Application Support" / "Google" / "Chrome",  # macOS
        home / ".config" / "google-chrome",                              # Linux
        home / ".config" / "chromium",
    ]


def _detect_logged_in_profiles() -> list[str]:
    """Chrome profile names with a live chatgpt.com session, freshest first.

    Read-only and offline: each profile's `Cookies` SQLite is copied and queried
    only for the `__Secure-next-auth.session-token` cookie's host/expiry — the
    encrypted value is never read or decrypted. Detects *whether* a profile is
    logged in, not which account; that's all the web backend needs to pick one.
    """
    import sqlite3

    # Chrome stores expiry as microseconds since 1601-01-01; convert "now".
    chrome_now_us = (time.time() + 11644473600) * 1_000_000
    found: list[tuple[str, int]] = []
    for base in _chrome_user_data_dirs():
        if not base.is_dir():
            continue
        for prof in base.iterdir():
            if not prof.is_dir() or not (prof / "Preferences").exists():
                continue
            db = next((c for c in (prof / "Network" / "Cookies", prof / "Cookies")
                       if c.exists()), None)
            if not db:
                continue
            tmp = None
            try:
                fd, tmp = tempfile.mkstemp(suffix=".db")
                os.close(fd)
                shutil.copy2(db, tmp)
                con = sqlite3.connect(f"file:{tmp}?mode=ro", uri=True)
                row = con.execute(
                    "SELECT MAX(expires_utc) FROM cookies "
                    "WHERE host_key LIKE '%chatgpt.com%' "
                    "AND name LIKE '__Secure-next-auth.session-token%'"
                ).fetchone()
                con.close()
                exp = row[0] if row else None
                if exp and exp > chrome_now_us:
                    found.append((prof.name, exp))
            except Exception:
                pass
            finally:
                if tmp:
                    try:
                        os.remove(tmp)
                    except Exception:
                        pass
    found.sort(key=lambda r: r[1], reverse=True)
    return [name for name, _exp in found]


def _relay_connected(ab: str) -> bool:
    """True if chrome-use's ab-connect relay is attached to a live Chrome.

    Reads `chrome-use daemon status --json` → data.relay — instant, no browser
    launch. The relay is the only way chrome-use can drive an ALREADY-open
    Chrome (a normally-launched Chrome has no debug port); knowing whether it's
    connected lets us tell a user with a logged-in-but-unreachable browser the
    right fix (connect the relay) instead of the misleading "not logged in".

    Best-effort: any error → False, so guidance degrades to generic remedies."""
    try:
        out = subprocess.run([ab, "daemon", "status", "--json"],
                             capture_output=True, text=True, timeout=10)
        data = json.loads(out.stdout or "{}")
        return bool(isinstance(data, dict)
                    and isinstance(data.get("data"), dict)
                    and data["data"].get("relay"))
    except Exception:  # noqa: BLE001 — diagnostics only, never fatal
        return False


def _auto_candidates(profiles: list[str], relay: bool) -> list[str | None]:
    """Order auto-mode browser candidates by where a usable browser most likely is.

    ``None`` is the relay (your already-open Chrome), which only drives a usable
    session when the ab-connect extension is connected. When it isn't, the relay
    candidate just launches a throwaway, signed-OUT temp profile that's bound to
    fail (and wastes a launch) — so when relay is down, try the offline-detected
    logged-in ``profiles`` FIRST and keep relay last (it still covers a Chrome
    manually exposed on a CDP port). Relay up → keep it first (best for
    anti-detection). Pure; no I/O."""
    return [None, *profiles] if relay else [*profiles, None]


def _web_unavailable_message(
    detected_profiles: list[str], reasons: list[str], relay: bool,
) -> str:
    """Build the WebUnavailable error after every browser candidate failed.

    Pure (no I/O) so it's unit-testable. ``reasons`` is the per-candidate
    failure list (each already prefixed with its label); ``detected_profiles``
    are the offline-detected logged-in Chrome profiles; ``relay`` is whether the
    ab-connect relay is attached.

    The point is to surface chrome-use's ACTUAL error (which the candidate loop
    used to swallow) plus a remedy tailored to the real situation, rather than a
    flat "no logged-in browser" that misreads a logged-in-but-unreachable Chrome
    as signed-out (issue #15)."""
    lines = ["no logged-in ChatGPT browser available."]
    if reasons:
        lines.append("tried:")
        lines += [f"  • {r}" for r in reasons]
    if detected_profiles and not relay:
        # A login WAS found on disk, but we couldn't drive it and the relay
        # isn't connected — so chrome-use can't reach the already-open Chrome.
        prof = detected_profiles[0]
        lines.append(
            f"a ChatGPT login was detected in Chrome profile {prof!r}, but it "
            "couldn't be driven. Fix any one:")
        lines.append(
            "  1. connect the relay (best — drives your already-open tab, no "
            "Codex-usage): run `chrome-use extension install`, load the "
            "ab-connect extension (chrome://extensions → Developer mode → Load "
            "unpacked), restart Chrome, then rerun.")
        lines.append(
            "  2. fully quit Chrome, then rerun — chrome-use can then launch the "
            f"logged-in profile {prof!r} itself.")
        lines.append("  3. use --backend codex (headless; bills Codex-usage).")
    elif relay:
        # The relay is up but the relayed Chrome still didn't yield a composer —
        # most likely that Chrome isn't signed in to chatgpt.com.
        lines.append(
            "the relay is connected but the open Chrome isn't usable — sign in "
            "to chatgpt.com in it, or use --backend codex.")
    else:
        lines.append(
            "no logged-in Chrome profile was detected and the relay isn't "
            "connected. Sign in to chatgpt.com (and/or set up the chrome-use "
            "relay), or use --backend codex.")
    return "\n".join(lines)


def _ab(ab: str, *ab_args: str, session: str, timeout: float, profile: str | None = None) -> str:
    """Run one chrome-use subcommand, return stdout. Raises GatewayError on failure.

    ``profile`` (a Chrome profile name/path) is passed as chrome-use's global
    ``--profile`` flag, which must precede the subcommand. Only the launching
    ``open`` call needs it; later calls reuse the session's browser.
    """
    cmd = [ab]
    if profile:
        cmd += ["--profile", profile]
    cmd += [*ab_args, "--session", session]
    try:
        proc = subprocess.run(
            cmd, capture_output=True, text=True, timeout=max(5.0, timeout)
        )
    except subprocess.TimeoutExpired:
        raise GatewayError(f"chrome-use timed out: {' '.join(ab_args[:2])}") from None
    except FileNotFoundError:
        raise GatewayError("chrome-use binary vanished mid-run") from None
    if proc.returncode != 0:
        tail = (proc.stderr or proc.stdout or "").strip().splitlines()[-3:]
        raise GatewayError(
            f"chrome-use {ab_args[0] if ab_args else ''} failed "
            f"(exit {proc.returncode}): {' / '.join(tail)[:300]}"
        )
    return proc.stdout


def _ab_eval(ab: str, js: str, session: str, timeout: float) -> Any:
    """Run JS in the page and decode the value it returns.

    Convention: the JS always `return JSON.stringify(value)`. chrome-use
    prints that string JSON-encoded, so we decode twice — once to recover the
    JSON text the page returned, once to parse it into a Python object.
    """
    out = _ab(ab, "eval", js, session=session, timeout=timeout)
    # Scan from the last non-empty line for the first that decodes to a string.
    for line in reversed([l for l in out.splitlines() if l.strip()]):
        try:
            inner = json.loads(line)
        except Exception:
            continue
        if isinstance(inner, str):
            try:
                return json.loads(inner)
            except Exception:
                return inner
        return inner
    raise GatewayError(f"could not parse chrome-use eval output: {out[:200]!r}")


# JS: snapshot the generation state — whether a stop/streaming control is still
# present, and the newest image asset src that was NOT already on the page when
# we started (baseline list passed in). Returned as a JSON string.
# Both the baseline and the freshness scan are scoped to `main img` — this
# tab's conversation thread — never document-wide. ChatGPT pushes an "Image
# created" toast (with a thumbnail whose src matches the asset regex) into ANY
# open chatgpt.com tab when some OTHER conversation finishes an image; the
# toast lives in a portal outside <main>, so a document-wide scan grabs that
# sibling's image (the cross-contaminated/duplicate outputs of issue #7) while
# a main-scoped scan can't. NOTE the generated <img> is NOT inside the
# [data-message-author-role="assistant"] element (verified in the live DOM:
# main#main > #thread > section[data-testid=conversation-turn-N] > … > img),
# so don't be tempted to scope tighter than <main>.
_JS_STATE = r"""(() => {
  const seen = new Set(%s);
  const stop = !!document.querySelector(
    'button[data-testid="stop-button"], button[aria-label*="Stop" i]'
  );
  const re = new RegExp(%s);
  // The generated image renders in <main> but OUTSIDE any message bubble (it's
  // an image-generation card, not an assistant text turn — so we can't scope to
  // the assistant role). An img2img reference, however, is echoed INSIDE the
  // user bubble with a fresh estuary/content src not in the pre-submit baseline.
  // So detect fresh main images but exclude any that belong to a user message.
  const userSrcs = new Set();
  document.querySelectorAll('[data-message-author-role="user"] img')
    .forEach(i => { const s = i.currentSrc || i.src; if (s) userSrcs.add(s); });
  const fresh = [...document.querySelectorAll('main img')]
    .map(i => i.currentSrc || i.src)
    .filter(s => re.test(s) && !seen.has(s) && !userSrcs.has(s));
  const a = document.querySelectorAll('[data-message-author-role="assistant"]');
  const lastA = a[a.length - 1];
  const dlg = [...document.querySelectorAll('[role="dialog"]')]
    .map(d => d.textContent || '').join(' ');
  return JSON.stringify({stop, last: fresh[fresh.length - 1] || null,
                         assistant: a.length > 0,
                         limited: /too many requests|requests too quickly/i.test(dlg),
                         atext: lastA ? lastA.textContent.trim().slice(0, 240) : ""});
})()"""

_JS_BASELINE = r"""(() => {
  const re = new RegExp(%s);
  const srcs = [...document.querySelectorAll('main img')]
    .map(i => i.currentSrc || i.src).filter(s => re.test(s));
  return JSON.stringify(srcs);
})()"""

# JS: fetch the asset bytes from inside the authenticated page and hand them
# back base64-encoded along with the content type. credentials:'include' reuses
# the browser's session cookies, so the signed/asset URL resolves.
_JS_FETCH = r"""(async () => {
  try {
    const r = await fetch(%s, {credentials: 'include'});
    if (!r.ok) return JSON.stringify({ok: false, status: r.status});
    const buf = new Uint8Array(await (await r.blob()).arrayBuffer());
    let bin = '';
    const CH = 0x8000;
    for (let i = 0; i < buf.length; i += CH)
      bin += String.fromCharCode.apply(null, buf.subarray(i, i + CH));
    return JSON.stringify({ok: true, type: r.headers.get('content-type'),
                           bytes: buf.length, b64: btoa(bin)});
  } catch (e) { return JSON.stringify({ok: false, error: String(e)}); }
})()"""

# JS: resolve a ChatGPT Project (a "snorlax" gizmo, id g-p-…) by exact display
# name, creating it if absent. Runs inside the authenticated page so the
# session cookies + accessToken are free. Endpoints (probed live, undocumented):
#   GET  /backend-api/gizmos/snorlax/sidebar   → list projects
#   POST /backend-api/projects {name, instructions} → create one
_JS_ENSURE_PROJECT = r"""(async () => {
  try {
    const name = %s;
    const sess = await fetch('/api/auth/session', {credentials: 'include'})
      .then(r => r.json()).catch(() => null);
    if (!sess || !sess.accessToken)
      return JSON.stringify({ok: false, error: 'no accessToken in /api/auth/session'});
    const h = {Authorization: 'Bearer ' + sess.accessToken,
               'Content-Type': 'application/json'};
    const find = async () => {
      const r = await fetch(
        '/backend-api/gizmos/snorlax/sidebar?conversations_per_gizmo=0',
        {credentials: 'include', headers: h});
      if (!r.ok) throw new Error('project list HTTP ' + r.status);
      for (const it of (await r.json()).items || []) {
        const g = it.gizmo && it.gizmo.gizmo;
        if (g && g.display && g.display.name === name) return g.id;
      }
      return null;
    };
    let id = await find();
    if (id) return JSON.stringify({ok: true, id, created: false});
    const mk = await fetch('/backend-api/projects', {
      method: 'POST', credentials: 'include', headers: h,
      body: JSON.stringify({name: name, instructions: ''})});
    if (!mk.ok) return JSON.stringify({ok: false, error: 'project create HTTP ' + mk.status});
    const j = await mk.json().catch(() => null);
    id = j && ((j.gizmo && (j.gizmo.id || (j.gizmo.gizmo && j.gizmo.gizmo.id))) || j.id);
    if (!id) id = await find();  // response shape unknown-proof: re-list by name
    if (!id) return JSON.stringify({ok: false, error: 'created but could not resolve id'});
    return JSON.stringify({ok: true, id, created: true});
  } catch (e) { return JSON.stringify({ok: false, error: String(e)}); }
})()"""


# JS: is the composer up — and is chatgpt.com showing its rate-limit dialog?
# ("Too many requests — You're making requests too quickly. We've temporarily
# limited access to your conversations…"). The dialog means every further page
# action is pointless for a few minutes, so surface it instead of timing out.
_JS_COMPOSER = r"""(() => {
  const dlg = [...document.querySelectorAll('[role="dialog"]')]
    .map(d => d.textContent || '').join(' ');
  return JSON.stringify({
    composer: !!document.querySelector('#prompt-textarea'),
    limited: /too many requests|requests too quickly/i.test(dlg),
  });
})()"""

_RATE_LIMIT_MSG = (
    "chatgpt.com rate-limited this account ('Too many requests') — the page "
    "surface needs a few minutes of quiet before it will serve again."
)


def _wait_composer(ab: str, session: str, remaining, tries: int = 15) -> bool:
    """Poll until the chat composer (#prompt-textarea) is on the page.

    Raises WebRateLimited if the page shows the "Too many requests" dialog —
    waiting out the poll budget (and then other profile candidates) would just
    burn ~45s each on an account-level block."""
    for _ in range(tries):
        try:
            st = _ab_eval(ab, _JS_COMPOSER, session=session,
                          timeout=min(20.0, remaining()))
            if isinstance(st, dict):
                if st.get("limited"):
                    raise WebRateLimited(_RATE_LIMIT_MSG)
                if st.get("composer"):
                    return True
        except WebRateLimited:
            raise
        except GatewayError:
            pass
        time.sleep(1.0)
    return False


def _enter_project(ab: str, session: str, name: str, remaining, emit) -> None:
    """Navigate the open session into the named ChatGPT Project, creating the
    project on first use — so each run's conversation files under the project
    instead of littering the top-level chat history.

    Best-effort: organization is a nicety, the generation is the point. On any
    failure this warns and restores a plain new chat, never aborts the run.
    """
    navigated = False
    try:
        res = _ab_eval(ab, _JS_ENSURE_PROJECT % json.dumps(name),
                       session=session, timeout=min(30.0, remaining()))
        if not isinstance(res, dict) or not res.get("ok") or not res.get("id"):
            detail = res.get("error") if isinstance(res, dict) else res
            raise GatewayError(f"could not resolve project: {detail}")
        emit(f"using project {name!r}" + (" (created)" if res.get("created") else ""))
        navigated = True
        _ab(ab, "open", WEB_PROJECT_URL.format(gizmo_id=res["id"]),
            session=session, timeout=min(30.0, remaining()))
        if not _wait_composer(ab, session, remaining):
            raise GatewayError("project page composer never appeared")
    except WebRateLimited:
        raise  # account-level block; a plain chat would be just as dead
    except GatewayError as e:
        emit(f"warning: project {name!r} unavailable ({e}); using a plain chat")
        if navigated:
            # We may have left the plain-chat page; restore it so the normal
            # submit flow still has a composer to type into.
            try:
                _ab(ab, "open", WEB_NEW_CHAT_URL, session=session,
                    timeout=min(30.0, remaining()))
                _wait_composer(ab, session, remaining)
            except GatewayError:
                pass


# JS: delete (hide) the conversation currently open in the tab. ChatGPT's own
# "delete" is a PATCH with `is_visible:false` — it drops the chat from history,
# search, and the sidebar. Conversation id comes from the `/c/<id>` URL segment
# (works for both plain `/c/…` and project `/g/g-p-…/c/…` URLs). accessToken is
# read from the in-page session, same as _JS_ENSURE_PROJECT.
_JS_DELETE_CONV = r"""(async () => {
  try {
    const m = location.pathname.match(/\/c\/([0-9a-f-]{16,})/i);
    if (!m) return JSON.stringify({ok: false, error: 'no conversation id in URL'});
    const id = m[1];
    const sess = await fetch('/api/auth/session', {credentials: 'include'})
      .then(r => r.json()).catch(() => null);
    if (!sess || !sess.accessToken)
      return JSON.stringify({ok: false, error: 'no accessToken in /api/auth/session'});
    const r = await fetch('/backend-api/conversation/' + id, {
      method: 'PATCH', credentials: 'include',
      headers: {Authorization: 'Bearer ' + sess.accessToken,
                'Content-Type': 'application/json'},
      body: JSON.stringify({is_visible: false})});
    if (!r.ok) return JSON.stringify({ok: false, error: 'delete HTTP ' + r.status});
    return JSON.stringify({ok: true, id});
  } catch (e) { return JSON.stringify({ok: false, error: String(e)}); }
})()"""


def _delete_conversation(ab, session, remaining, emit) -> None:
    """Delete the conversation just used so the run leaves no history.

    Best-effort: the image is already saved by the time we get here, so a delete
    failure only warns — it never fails the run or loses the image.
    """
    try:
        res = _ab_eval(ab, _JS_DELETE_CONV, session=session,
                       timeout=min(20.0, remaining()))
    except GatewayError as e:
        emit(f"warning: could not delete conversation ({e}); it stays in history")
        return
    if isinstance(res, dict) and res.get("ok"):
        emit("conversation deleted (no history kept)")
    else:
        detail = res.get("error") if isinstance(res, dict) else res
        emit(f"warning: could not delete conversation ({detail}); it stays in history")


# JS: locate the composer model-picker button and return its label + viewport
# center {text, x, y}, or null. The picker has no stable selector, so match the
# one menu-opening button whose short label names a model/effort.
_JS_MODEL_BTN = r"""(() => {
  const b = [...document.querySelectorAll('button')].find(b =>
    b.getAttribute('aria-haspopup') === 'menu' &&
    (b.innerText || '').trim().length > 0 &&
    (b.innerText || '').trim().length < 25 &&
    /\b(Auto|Pro|Instant|Medium|High|Thinking|Fast|GPT)\b/.test(b.innerText || ''));
  if (!b) return JSON.stringify(null);
  const r = b.getBoundingClientRect();
  return JSON.stringify({text: b.innerText.replace(/\s+/g, ' ').trim(),
                         x: Math.round(r.x + r.width / 2),
                         y: Math.round(r.y + r.height / 2)});
})()"""

# JS: find an open-menu radio/item by exact label, return its center {x, y}.
_JS_MENU_ITEM = r"""(() => {
  const name = %s;
  const m = [...document.querySelectorAll('[role="menuitemradio"],[role="menuitem"]')]
    .find(e => (e.innerText || '').replace(/\s+/g, ' ').trim() === name);
  if (!m) return JSON.stringify(null);
  const r = m.getBoundingClientRect();
  return JSON.stringify({x: Math.round(r.x + r.width / 2),
                         y: Math.round(r.y + r.height / 2)});
})()"""


def _ensure_web_model(ab, session, model_label, remaining, emit) -> None:
    """Switch the composer to the first available of ``model_label`` (a
    comma-separated candidate list, e.g. "Instant,Auto").

    Needed because "Pro" has no native image generator (see WEB_MODEL_DEFAULT).
    Different plans label the image-capable tier differently (Plus/Pro expose
    Instant/Medium/…; other plans an "Auto"), so we try a list and take the first
    that exists in the picker — more robust than one hardcoded label. The menu
    renders in a React portal that ignores synthetic ``.click()`` and re-renders
    away injected ids, so we drive it by real coordinate clicks read fresh from
    getBoundingClientRect each step.

    Best-effort: on any failure this warns and proceeds with the current model,
    exactly like _enter_project — selection is a nicety, not worth aborting over.
    """
    candidates = [c.strip() for c in (model_label or "").split(",") if c.strip()]
    if not candidates:
        return
    wants = [c.lower() for c in candidates]
    try:
        btn = _ab_eval(ab, _JS_MODEL_BTN, session=session,
                       timeout=min(15.0, remaining()))
        if not isinstance(btn, dict):
            emit("warning: model picker not found; leaving model as-is")
            return
        cur_text = btn.get("text", "").strip().lower()
        if any(cur_text.startswith(w) for w in wants):
            return  # already on an acceptable model (picker is sticky)
        emit(f"switching model {btn.get('text')!r} → first of {candidates}")
        _ab(ab, "click", str(btn["x"]), str(btn["y"]),
            session=session, timeout=min(15.0, remaining()))
        time.sleep(0.6)
        chosen = None
        item = None
        for cand in candidates:  # first candidate present in the open menu wins
            it = _ab_eval(ab, _JS_MENU_ITEM % json.dumps(cand),
                          session=session, timeout=min(15.0, remaining()))
            if isinstance(it, dict):
                chosen, item = cand, it
                break
        if item is None:
            emit(f"warning: none of {candidates} in the picker; leaving as-is")
            try:  # close the menu so it can't swallow the prompt
                _ab(ab, "press", "Escape", session=session,
                    timeout=min(10.0, remaining()))
            except GatewayError:
                pass
            return
        _ab(ab, "click", str(item["x"]), str(item["y"]),
            session=session, timeout=min(15.0, remaining()))
        time.sleep(0.4)
        now = _ab_eval(ab, _JS_MODEL_BTN, session=session,
                       timeout=min(15.0, remaining()))
        cur = now.get("text") if isinstance(now, dict) else None
        if isinstance(cur, str) and cur.strip().lower().startswith(chosen.lower()):
            emit(f"model set to {chosen!r}")
        else:
            emit(f"warning: model may not have switched (now {cur!r})")
    except WebRateLimited:
        raise
    except GatewayError as e:
        emit(f"warning: could not switch model ({e}); using the current one")


def _env_bool(name: str) -> bool:
    """True if env var ``name`` is set to a truthy value (1/true/yes/on)."""
    return os.environ.get(name, "").strip().lower() in ("1", "true", "yes", "on")


def _backend_limit(kind: str, default: int) -> int:
    """Concurrency cap for a backend, via CHATGPT_IMAGEGEN_<KIND>_CONCURRENCY.

    0 or a negative value means unlimited. Unset / unparsable → the default.
    """
    raw = os.environ.get(f"CHATGPT_IMAGEGEN_{kind.upper()}_CONCURRENCY", "").strip()
    try:
        return int(raw) if raw else default
    except ValueError:
        return default


# Per-backend defaults. They differ because the backends hit different limits:
#   web   — drives the ONE shared logged-in Chrome AND the chatgpt.com page
#           surface, which rate-limits aggressively ("Too many requests …
#           temporarily limited access to your conversations"). Keep it at 1.
#   codex — independent HTTP POSTs; measured fine at 4 concurrent on a Plus
#           account (no 429s, no serialization). Cap it anyway so an agent
#           fanning out a big batch can't trip the per-account limiter.
WEB_CONCURRENCY_DEFAULT = 1
CODEX_CONCURRENCY_DEFAULT = 4


@contextmanager
def _concurrency_slot(kind: str, limit: int, progress: bool, start: float) -> "Iterator[None]":
    """Cross-process counting semaphore: at most ``limit`` concurrent runs.

    Implemented as ``limit`` flock slot files in the temp dir — a run holds
    exactly one slot for its whole generation. Excess runs queue (0.5s poll)
    instead of failing or corrupting each other (issue #7: parallel web runs
    cross-contaminated images; the page surface also rate-limits hard). The
    kernel releases a slot when its holder dies, so a crash can't wedge the
    queue. ``limit <= 0`` disables the gate entirely.
    """
    if limit <= 0:
        yield
        return
    base = tempfile.gettempdir()
    slot = None
    announced = False
    try:
        while slot is None:
            for i in range(limit):
                f = open(os.path.join(base, f"chatgpt-imagegen-{kind}-{i}.lock"), "w")
                try:
                    fcntl.flock(f, fcntl.LOCK_EX | fcntl.LOCK_NB)
                    slot = f
                    break
                except OSError:
                    f.close()
            else:
                if progress and not announced:
                    announced = True
                    print(
                        f"[{time.monotonic() - start:6.1f}s] waiting for a free "
                        f"{kind} slot (max {limit} concurrent {kind} generation"
                        f"{'s' if limit != 1 else ''})",
                        file=sys.stderr,
                    )
                time.sleep(0.5)
        yield
    finally:
        if slot is not None:
            try:
                fcntl.flock(slot, fcntl.LOCK_UN)
            except OSError:
                pass
            slot.close()


def run_web(
    args: argparse.Namespace, progress: bool, start: float,
    refs: list[str] | None = None,
) -> tuple[bytes, JsonDict]:
    """Generate an image by driving the user's logged-in ChatGPT browser.

    When ``refs`` (reference image paths/URLs) are supplied, runs image-to-image:
    each reference is attached to the composer via `chrome-use upload` before the
    edit prompt is submitted — no Codex-usage, same surface as text-to-image.

    Returns (image_bytes, meta). Raises GatewayError / exits on failure.
    """
    ab = _find_agent_browser()
    if ab is None:
        raise WebUnavailable(f"`chrome-use` is not installed — {_AB_INSTALL_HINT}")
    # Default to a STABLE session name so we reuse one chrome-use daemon instead
    # of leaking a fresh `imagegen-<pid>` daemon every run (chrome-use has no
    # clean daemon-reap command yet — see leeguooooo/chrome-use#48). Safe because
    # web runs are serialized to 1 by the concurrency gate; only if the user
    # lifts that cap do we fall back to a per-pid session so parallel runs don't
    # share — and cross-contaminate (issue #7) — the same tab.
    if args.session:
        session = args.session
    elif _backend_limit("web", WEB_CONCURRENCY_DEFAULT) == 1:
        session = "imagegen"
    else:
        session = f"imagegen-{os.getpid()}"
    # Budget the generation from NOW, not from process start: web runs may have
    # blocked on the serialize lock (issue #7) before reaching here, and that
    # queue wait must not eat into the --timeout image budget.
    deadline = time.monotonic() + args.timeout
    _n_char, _n_style = _ref_counts(args, refs)
    user_text = _build_web_text(
        args.gen_prompt, args.size,
        n_character_refs=_n_char, n_style_refs=_n_style)

    def emit(msg: str) -> None:
        if progress:
            print(_fmt_progress(time.monotonic() - start, msg), file=sys.stderr)

    def remaining() -> float:
        return max(2.0, deadline - time.monotonic())

    _warn_if_chrome_use_old(ab, emit)

    # Decide which browser(s) to try, in order.
    #   relay/off  → only the currently-open Chrome (extension relay).
    #   auto       → relay FIRST (your open Chrome usually works and is best for
    #                anti-detection), then any offline-detected profile that's
    #                logged in to chatgpt.com — so we only switch profiles when
    #                the open browser isn't logged in.
    #   <name>     → only that profile.
    # `None` in the list means "relay" (no --profile flag).
    pl = (args.profile or "auto").strip().lower()
    # Probe the relay once up front: it decides candidate ORDER (below) and the
    # remedy in the final error (so we don't re-shell `daemon status`).
    relay = _relay_connected(ab)
    if pl in ("relay", "off", "current"):
        candidates: list[str | None] = [None]
    elif pl == "auto":
        candidates = _auto_candidates(_detect_logged_in_profiles(), relay)
    else:
        candidates = [args.profile.strip()]
    if pl == "auto":
        emit(f"relay {'connected' if relay else 'not connected'}")

    def _try_open(prof: str | None) -> str | None:
        """Open a fresh chat and wait for the composer.

        Returns None on success, or a short reason string on failure — the
        chrome-use error verbatim, or "composer never appeared". We surface that
        reason instead of swallowing it (the old bool dropped chrome-use's
        actual diagnostic, e.g. "extension not connected …", leaving the user
        only our generic message — issue #15). WebRateLimited still propagates."""
        try:
            _ab(ab, "open", WEB_NEW_CHAT_URL, session=session,
                timeout=min(30.0, remaining()), profile=prof)
        except GatewayError as e:
            return str(e)
        if _wait_composer(ab, session, remaining):
            return None
        return ("composer never appeared (likely a login wall — that Chrome "
                "isn't signed in to chatgpt.com — or the page was blocked)")

    def _close() -> None:
        """Close the session's browser/tab. Best-effort; never raises."""
        try:
            _ab(ab, "close", session=session, timeout=15.0)
        except Exception:
            pass  # leftover tab is harmless; never fail the run over cleanup

    chosen: str | None = None
    opened = False
    reasons: list[str] = []  # per-candidate failure, surfaced if all fail
    for prof in candidates:
        label = "current Chrome (relay)" if prof is None else f"profile {prof!r}"
        emit(f"opening ChatGPT via {label}")
        try:
            reason = _try_open(prof)
        except WebRateLimited:
            _close()  # account-level block: stop burning 45s per candidate
            raise
        if reason is None:
            chosen, opened = prof, True
            emit(f"using {label}")
            break
        emit(f"{label} unavailable: {reason}")
        reasons.append(f"{label} — {reason}")
        _close()  # always tear down a failed attempt, including the last
    if not opened:
        detected = [c for c in candidates if c is not None]
        raise WebUnavailable(_web_unavailable_message(detected, reasons, relay))

    # Everything past here drives the now-open browser. Wrap it so the tab is
    # ALWAYS closed on the way out — success, failure (quota/refusal/timeout), or
    # exception — instead of leaking a window on every non-happy path.
    try:
        project = (args.project or "").strip()
        if project:
            _enter_project(ab, session, project, remaining, emit)
        _ensure_web_model(
            ab, session,
            getattr(args, "web_model", WEB_MODEL_DEFAULT) or WEB_MODEL_DEFAULT,
            remaining, emit)
        result = _generate_in_browser(
            ab, session, user_text, args, deadline, remaining, emit, refs=refs)
        # Image is saved by now. Delete the conversation so no history is left —
        # the default. `--keep-conversation` opts out; `--keep-tab` (debugging)
        # implies keeping it, since an open tab on a deleted chat is useless.
        if not getattr(args, "keep_conversation", False) and not args.keep_tab:
            _delete_conversation(ab, session, remaining, emit)
        return result
    finally:
        if not args.keep_tab:
            _close()


def _resolve_ref_path(ref: str) -> tuple[str, str | None]:
    """Return (local_path, cleanup_path|None) for a local path or http(s) URL.

    Web img2img hands a real file to `chrome-use upload`, so — unlike the codex
    helper `_load_reference` — we keep the file on disk rather than base64ing it.
    URLs download to a temp file the caller deletes via the returned cleanup
    path. Exits cleanly on a missing file / unsupported type / download failure.
    """
    if _is_url(ref):
        raw = _download_ref_url(ref)
        mime = _sniff_mime(raw)
        if mime is None:
            sys.exit(f"unsupported reference image type for {ref!r} (need PNG, JPEG, or WEBP)")
        ext = {"image/png": ".png", "image/jpeg": ".jpg",
               "image/webp": ".webp"}.get(mime, ".img")
        fd, tmp = tempfile.mkstemp(suffix=ext)
        os.close(fd)
        Path(tmp).write_bytes(raw)
        return tmp, tmp
    p = Path(ref).expanduser()
    if not p.is_file():
        sys.exit(f"reference image not found: {ref}")
    with p.open("rb") as fh:
        if _sniff_mime(fh.read(16)) is None:
            sys.exit(f"unsupported reference image type for {ref!r} (need PNG, JPEG, or WEBP)")
    return str(p), None


# JS: count reference attachments sitting in the composer (uploaded, not yet
# sent). Used to confirm an upload landed before we submit the edit prompt.
_JS_PENDING_UPLOADS = r"""(() => {
  const form = document.querySelector('form') || document.body;
  const imgs = [...form.querySelectorAll('img')]
    .filter(i => /blob:|estuary\/content|oaiusercontent/.test(i.src || ''));
  return JSON.stringify(imgs.length);
})()"""


def _upload_references(ab, session, ref_paths, remaining, emit) -> None:
    """Attach reference image files to the composer via `chrome-use upload`.

    ChatGPT's composer exposes a standard <input accept="image/*">, so the
    generic upload command drives it with NO ChatGPT-specific support needed.
    Waits for the thumbnail(s) to render so the caller's baseline capture counts
    them as pre-existing — never mistaking a reference for the generated result.
    """
    emit(f"attaching {len(ref_paths)} reference image(s)")
    _ab(ab, "upload", 'input[accept="image/*"]', *ref_paths,
        session=session, timeout=min(90.0, remaining()))
    for _ in range(15):  # best-effort confirmation; proceed regardless
        try:
            n = _ab_eval(ab, _JS_PENDING_UPLOADS, session=session,
                         timeout=min(10.0, remaining()))
        except GatewayError:
            n = 0
        if isinstance(n, int) and n >= 1:
            emit("reference attached")
            time.sleep(2.0)  # let the upload finalise server-side before we send
            return
        time.sleep(1.0)
    emit("warning: reference attachment not confirmed; submitting anyway")


def _generate_in_browser(ab, session, user_text, args, deadline, remaining, emit,
                         refs=None):
    # Image-to-image: attach the reference(s) to the composer FIRST, then delete
    # any temp downloads — the browser has uploaded the bytes to ChatGPT by the
    # time the thumbnail renders, so the local copy is no longer needed.
    if refs:
        ref_paths: list[str] = []
        cleanups: list[str] = []
        for r in refs:
            path, cleanup = _resolve_ref_path(r)
            ref_paths.append(path)
            if cleanup:
                cleanups.append(cleanup)
        _upload_references(ab, session, ref_paths, remaining, emit)
        for c in cleanups:
            try:
                os.unlink(c)
            except OSError:
                pass

    # Capture the baseline set of image srcs already on the page so we never
    # mistake a prior image — INCLUDING a just-uploaded reference, whose src is
    # also an estuary/content URL — for the new one.
    baseline = _ab_eval(ab, _JS_BASELINE % json.dumps(WEB_IMG_SRC_RE),
                        session=session, timeout=min(20.0, remaining()))
    if not isinstance(baseline, list):
        baseline = []

    emit("submitting prompt")
    # The composer is a ProseMirror/React contenteditable. `fill` mutates the
    # DOM without firing the input events React listens for, so the send button
    # stays bound to empty state and nothing submits. Real keystrokes via
    # `keyboard type` go through ProseMirror's input path and update React, so
    # both Enter and the send button then work.
    _ab(ab, "click", "#prompt-textarea", session=session, timeout=min(20.0, remaining()))
    _ab(ab, "keyboard", "type", user_text, session=session, timeout=min(60.0, remaining()))

    def _composer_empty() -> bool:
        # A sent message clears the composer; an empty composer is our proof the
        # submit actually left the page (vs. a swallowed Enter leaving it stuck).
        try:
            return bool(_ab_eval(
                ab,
                "(() => { const t=(document.querySelector('#prompt-textarea')||{})"
                ".textContent||''; return JSON.stringify(t.trim().length===0); })()",
                session=session, timeout=min(15.0, remaining())))
        except GatewayError:
            return False

    # Retry until the composer empties. With an attached reference the send button
    # is briefly disabled while the upload finalises server-side, so the first
    # Enter (or send click) can be swallowed — a single attempt would leave the
    # prompt stuck in the box and the poll below would hang until timeout.
    sent = False
    for _ in range(6):
        _ab(ab, "press", "Enter", session=session, timeout=min(20.0, remaining()))
        time.sleep(1.0)
        if _composer_empty():
            sent = True
            break
        try:
            _ab(ab, "click", 'button[data-testid="send-button"]',
                session=session, timeout=min(15.0, remaining()))
        except GatewayError:
            pass
        time.sleep(1.5)
        if _composer_empty():
            sent = True
            break
    if not sent:
        emit("warning: composer did not clear — the prompt may not have sent")

    # Poll until the stream stops AND a brand-new image asset is present and
    # stable across two reads (guards against grabbing a mid-render partial).
    state_js = _JS_STATE % (json.dumps(baseline), json.dumps(WEB_IMG_SRC_RE))
    last_phase = ""
    final_src: str | None = None
    stable_src: str | None = None
    # Idle = an assistant turn exists, nothing is streaming, and still no image.
    # After ~16s of that we conclude the reply finished without an image (refusal,
    # text-only, or an empty turn) instead of hanging until the total timeout.
    idle_polls = 0
    IDLE_LIMIT = 8
    last_atext = ""
    while time.monotonic() < deadline:
        time.sleep(2.0)
        try:
            st = _ab_eval(ab, state_js, session=session, timeout=min(20.0, remaining()))
        except GatewayError:
            continue
        if not isinstance(st, dict):
            continue
        if st.get("limited"):
            # Post-submit rate limit: a plain GatewayError on purpose — the
            # prompt already went in, so auto mode must NOT double-spend by
            # silently retrying on codex.
            raise GatewayError(
                _RATE_LIMIT_MSG + " The prompt was already submitted; check "
                "the conversation later or retry in a few minutes."
            )
        if st.get("stop"):
            if last_phase != "generating":
                last_phase = "generating"
                emit("generating")
            stable_src = None
            idle_polls = 0
            continue
        cur = st.get("last")
        if cur:
            if last_phase not in ("receiving image", "done"):
                last_phase = "receiving image"
                emit("receiving image")
            idle_polls = 0
            # Require the same fresh src twice in a row before trusting it.
            if cur == stable_src:
                final_src = cur
                break
            stable_src = cur
        elif st.get("assistant"):
            # Assistant turn present, not streaming, no new image yet.
            if isinstance(st.get("atext"), str) and st["atext"]:
                last_atext = st["atext"]
            idle_polls += 1
            if idle_polls >= IDLE_LIMIT:
                reason = f' ChatGPT said: "{last_atext}"' if last_atext else ""
                raise GatewayError(
                    "ChatGPT finished without producing an image (text reply, "
                    "refusal, or image quota reached)." + reason +
                    " Try rephrasing, a different --profile, or --backend codex."
                )

    if not final_src:
        raise GatewayError(
            f"timed out after {args.timeout}s waiting for the image "
            f"(last phase: {last_phase or 'connecting'})."
        )

    emit("downloading image bytes")
    res = _ab_eval(ab, _JS_FETCH % json.dumps(final_src),
                  session=session, timeout=min(60.0, remaining()))
    if not isinstance(res, dict) or not res.get("ok"):
        detail = res.get("status") or res.get("error") if isinstance(res, dict) else res
        raise GatewayError(f"failed to download the generated image: {detail}")
    try:
        image_bytes = base64.b64decode(res["b64"], validate=True)
    except Exception:
        raise GatewayError("generated image came back as invalid base64") from None

    meta: JsonDict = {"content_type": res.get("type"), "source": "web"}
    # Cleanup (closing the tab) is handled by run_web's finally, so it runs on
    # every exit path — not just this success one.
    return image_bytes, meta


# ---------- save ----------

def _default_out_path(prompt: str, fmt: str) -> Path:
    slug = re.sub(r"[^a-z0-9]+", "-", prompt.lower()).strip("-")[:60] or "image"
    base = Path("assets/generated")
    base.mkdir(parents=True, exist_ok=True)
    i = 1
    while True:
        candidate = base / (f"{slug}.{fmt}" if i == 1 else f"{slug}-{i}.{fmt}")
        if not candidate.exists():
            return candidate
        i += 1


def _maybe_warn_extension_mismatch(out_path: Path, fmt: str) -> None:
    ext = out_path.suffix.lower().lstrip(".")
    # Map jpg <-> jpeg as equivalent.
    canon = "jpeg" if ext == "jpg" else ext
    if canon and canon != fmt:
        print(
            f"   .. warning: --format={fmt} but {out_path.name} has .{ext} extension; "
            f"writing {fmt} bytes anyway",
            file=sys.stderr,
        )


def _positive_int(value: str) -> int:
    try:
        v = int(value)
    except ValueError:
        raise argparse.ArgumentTypeError(f"must be a positive integer: {value!r}")
    if v <= 0:
        raise argparse.ArgumentTypeError(f"must be a positive integer: {value!r}")
    return v


# ---------- codex backend (headless responses API) ----------

def run_codex(
    args: argparse.Namespace, progress: bool, stall_timeout: float, start: float,
    refs: list[str] | None = None,
) -> tuple[bytes, JsonDict]:
    """Generate an image via the headless codex/responses endpoint.

    Fast and dependency-free, but every call bills the metered Codex-usage
    bucket. Returns (image_bytes, meta); exits on unrecoverable failure.

    When `refs` (reference image paths/URLs) are supplied, runs image-to-image:
    each reference is attached as an `input_image` content part and the image
    tool is forced (`tool_choice: required`).

    Concurrency is gated at CODEX_CONCURRENCY_DEFAULT (4) parallel runs by a
    cross-process semaphore — wide enough for real fan-out, tight enough that a
    big agent batch can't trip the per-account limiter. Tune (or disable with
    0) via CHATGPT_IMAGEGEN_CODEX_CONCURRENCY.
    """
    auth = _load_auth()
    access, account_id, refresh = _extract_access_token(auth)
    if not access:
        sys.exit(
            "no ChatGPT OAuth access_token in ~/.codex/auth.json. "
            "Run `codex login` to sign into your ChatGPT subscription. "
            "(An OPENAI_API_KEY in this file is not a substitute — the backend "
            "requires a subscription OAuth token.)"
        )

    loaded_refs: list[tuple[str, str]] | None = None
    if refs:
        loaded_refs = [_load_reference(r) for r in refs]
        if progress:
            approx = sum(len(b64) for b64, _ in loaded_refs)
            print(
                f"[{time.monotonic() - start:6.1f}s] image-to-image: "
                f"{len(loaded_refs)} reference(s), ~{approx // 1024} KB base64",
                file=sys.stderr,
            )

    version = _detect_codex_version()
    n_char, n_style = _ref_counts(args, refs)
    payload = _build_payload(args.gen_prompt, args.size, args.format, args.model,
                             refs=loaded_refs,
                             n_character_refs=n_char, n_style_refs=n_style)

    with _concurrency_slot("codex", _backend_limit("codex", CODEX_CONCURRENCY_DEFAULT),
                           progress, start):
        return _run_codex_locked(
            args, progress, stall_timeout, start, payload, account_id, access,
            refresh, version, auth)


def _run_codex_locked(
    args, progress, stall_timeout, start, payload, account_id, access,
    refresh, version, auth,
) -> tuple[bytes, JsonDict]:
    # Budget from NOW, not process start: the run may have queued on the codex
    # concurrency slot, and that wait must not eat the --timeout image budget.
    deadline = time.monotonic() + args.timeout

    def _attempt(token: str) -> tuple[bytes, JsonDict]:
        headers = _build_headers(token, account_id, version)
        return _post_for_image(payload, headers, deadline, start, stall_timeout, progress)

    try:
        return _attempt(access)
    except GatewayError as e:
        # Auto-refresh on 401/403 once, then retry. Any other error → fail clean.
        if e.status in (401, 403) and refresh:
            if progress:
                print(f"[{time.monotonic() - start:6.1f}s] access token expired; refreshing",
                      file=sys.stderr)
            try:
                refreshed = _refresh_access_token(refresh)
            except GatewayError as re_err:
                sys.exit(str(re_err))
            except Exception as re_err:
                # Never include the refresh response body / token material in the message.
                sys.exit(f"token refresh failed: {type(re_err).__name__}")
            new_access = refreshed.get("access_token")
            if not isinstance(new_access, str) or not new_access:
                # Avoid leaking the dict (may contain id_token / refresh_token).
                present = sorted(k for k in refreshed if isinstance(refreshed.get(k), str))
                sys.exit(
                    f"refresh response missing access_token "
                    f"(present string fields: {present})"
                )
            try:
                _persist_refreshed_auth(auth, refreshed)
            except Exception as p_err:
                # Always warn on persistence failure, even in quiet mode — stale
                # tokens on next run will look like a mysterious failure otherwise.
                print(
                    f"warning: could not persist refreshed token to {AUTH_PATH}: "
                    f"{type(p_err).__name__}: {p_err}",
                    file=sys.stderr,
                )
            try:
                return _attempt(new_access)
            except GatewayError as retry_err:
                sys.exit(str(retry_err))
        else:
            sys.exit(str(e))


# ---------- backend routing ----------

def _dispatch(
    args: argparse.Namespace, progress: bool, stall_timeout: float, start: float
) -> tuple[bytes, JsonDict]:
    """Pick a backend and run it.

    auto  : prefer web (spares Codex-usage); fall back to codex only when the
            web backend is *unavailable* (no chrome-use / browser not
            reachable / not logged in). A web failure that happens after the
            prompt was submitted is NOT silently retried on codex — that would
            spend the very bucket auto-mode is trying to protect.
    web   : force web; any failure is fatal (with guidance).
    codex : force codex.
    """
    def note(msg: str) -> None:
        if progress:
            print(_fmt_progress(time.monotonic() - start, msg), file=sys.stderr)

    # main() has already resolved the active asset set, partitioned it into
    # character/style groups, applied the total-ref cap, and stored the ordered
    # file list (asset refs + ad-hoc --ref) on args. Fall back to the raw --ref
    # list if that machinery didn't run (defensive).
    refs = getattr(args, "resolved_refs", None)
    if refs is None:
        refs = getattr(args, "ref", None)
    refs = refs or None
    # Image-to-image (refs) is now supported on BOTH backends: web attaches the
    # reference to the composer via `chrome-use upload`, codex sends it as an
    # input_image part. So refs ride the normal backend selection below — auto
    # still prefers web (spares Codex-usage), exactly like text-to-image.

    if args.backend == "codex":
        return run_codex(args, progress, stall_timeout, start, refs=refs)

    web_limit = _backend_limit("web", WEB_CONCURRENCY_DEFAULT)

    if args.backend == "web":
        try:
            with _concurrency_slot("web", web_limit, progress, start):
                return run_web(args, progress, start, refs=refs)
        except GatewayError as e:
            sys.exit(str(e))

    # auto
    try:
        with _concurrency_slot("web", web_limit, progress, start):
            return run_web(args, progress, start, refs=refs)
    except WebUnavailable as e:
        if _codex_token_present():
            if _find_agent_browser() is None:
                # chrome-use isn't installed. Keep this to a *gentle* one-line
                # tip — never dump install commands here, and never install on
                # the user's behalf. Full setup guidance lives in the README /
                # skill and is for when the user explicitly opts in.
                note("chrome-use not installed; falling back to codex "
                     "(bills the metered Codex-usage bucket).")
                note("tip: with chrome-use installed, generation runs through "
                     "your logged-in browser and costs no Codex usage.")
            else:
                note(f"web backend unavailable ({e}); falling back to codex "
                     f"(this consumes Codex-usage).")
            return run_codex(args, progress, stall_timeout, start, refs=refs)
        sys.exit(
            "cannot generate an image — neither backend is ready:\n"
            f"  • web:   {e}\n"
            "  • codex: no ChatGPT OAuth token in ~/.codex/auth.json "
            "(run `npm i -g @openai/codex && codex login`).\n"
            "Set up either the logged-in browser (preferred — spares Codex-usage) "
            "or codex login."
        )
    except GatewayError as e:
        # Web was available but failed mid-generation. Don't silently burn the
        # Codex bucket; surface it and let the user decide (--backend codex).
        sys.exit(
            f"{e}\n(web backend was reachable, so auto-mode did not fall back to "
            f"codex — rerun with --backend codex to use the Codex-usage path.)"
        )


# ── Style presets ──────────────────────────────────────────────────────────
# Named, reusable prompt snippets appended (as a comma-joined suffix) to the
# user's prompt. Stored in ~/.config/chatgpt-imagegen/styles.json; seeded once
# from the built-ins below and never auto-overwritten (use `style reset`).
_BUILTIN_STYLES = {
    "doodle": (
        "drawn as a deliberately crude doodle using the biggest possible blocks "
        "of color, leaning hard into a scribbly, pathetically bad look. White "
        "background, as if drawn with a mouse in an old-school computer paint "
        "program. It should be faintly recognizable yet not quite right — like "
        "it almost matches but everything is subtly off, awkward and confusing. "
        "Low-res, smeared together pixel by pixel, showing off just how absurdly "
        "bad it is. Honestly, draw it however you want — but the content must "
        "still be readable."
    ),
}

_STYLE_NAME_RE = re.compile(r"^[a-z0-9][a-z0-9_-]*$")

# An "asset" (a v2 styles entry) is either a recurring character (reproduce it
# faithfully as the subject) or a style (match the aesthetic, not the content).
_STYLE_KINDS = ("character", "style")
# Extension a copied reference is normalized to, by sniffed MIME.
_REF_EXT_BY_MIME = {"image/png": "png", "image/jpeg": "jpg", "image/webp": "webp"}
# Default cap on how many reference images one generation may attach. The
# resolved set is ordered character-first; anything past the cap is dropped with
# a logged warning (never silently truncated).
REF_ATTACH_CAP = 4


def _valid_style_name(name: str) -> bool:
    """A style name is a lowercase slug: alnum/-/_ , starting alphanumeric."""
    return bool(_STYLE_NAME_RE.match(name or ""))


def _compose_prompt(user_prompt: str, snippet: str | None) -> str:
    """Append a style snippet to the prompt as a comma-joined suffix.

    Blank/None snippet → prompt unchanged. A single trailing ','/'.' on the
    prompt is dropped so the join reads cleanly. Pure; no I/O.
    """
    if not snippet or not snippet.strip():
        return user_prompt
    base = user_prompt.rstrip()
    if base and base[-1] in ",.":
        base = base[:-1].rstrip()
    snippet = snippet.strip()
    return f"{base}, {snippet}" if base else snippet


def _styles_path() -> Path:
    base = os.environ.get("XDG_CONFIG_HOME", "").strip()
    root = Path(base) if base else Path.home() / ".config"
    return root / "chatgpt-imagegen" / "styles.json"


# ---------- asset library (reference images pinned per asset) ----------

def _assets_root() -> Path:
    """Directory holding each asset's copied reference images
    (~/.config/chatgpt-imagegen/assets/)."""
    return _styles_path().parent / "assets"


def _asset_dir(name: str) -> Path:
    """The on-disk directory that holds asset ``name``'s reference images."""
    return _assets_root() / name


def _last_output_path() -> Path:
    """Tiny state file recording the most recently generated image (for
    `--from-last`)."""
    return _styles_path().parent / "last-output.json"


def _record_last_output(path: Path) -> None:
    """Record the absolute path of the just-saved image so `--from-last` can pin
    it later. Best-effort: this bookkeeping never fails a real generation."""
    try:
        p = _last_output_path()
        p.parent.mkdir(parents=True, exist_ok=True)
        tmp = p.with_name(p.name + ".tmp")
        tmp.write_text(
            json.dumps({"path": str(path.resolve()), "ts": time.time()}),
            encoding="utf-8")
        os.replace(tmp, p)
    except Exception:  # noqa: BLE001 — capture is a nicety, never fatal
        pass


def _read_last_output() -> Path | None:
    """The path recorded by the last successful generation, or None."""
    try:
        data = json.loads(_last_output_path().read_text(encoding="utf-8"))
    except Exception:  # noqa: BLE001
        return None
    p = data.get("path") if isinstance(data, dict) else None
    return Path(p) if isinstance(p, str) and p else None


def _resolve_from_last() -> str:
    """Path of the most recently generated image, for `--from-last`. Exits with
    an actionable message if nothing was recorded or the file is gone."""
    p = _read_last_output()
    if p is None:
        raise SystemExit(
            "error: --from-last: no recently generated image was recorded yet. "
            "Generate one first, or pass an explicit --ref <path>.")
    if not p.is_file():
        raise SystemExit(
            f"error: --from-last: the last generated image is gone ({p}). "
            f"Pass an explicit --ref <path> instead.")
    return str(p)


def _next_ref_index(asset_dir: Path, existing: list[str]) -> int:
    """Next free `ref-<n>` index, considering both the entry's recorded refs and
    whatever already sits in the asset dir (so copies never collide)."""
    nums = [0]
    names = list(existing)
    if asset_dir.is_dir():
        names += [f.name for f in asset_dir.iterdir()]
    for nm in names:
        m = re.match(r"ref-(\d+)\.", nm)
        if m:
            nums.append(int(m.group(1)))
    return max(nums) + 1


def _copy_ref_into_asset(asset_dir: Path, src: str, existing: list[str]) -> str:
    """Validate, downsize-if-needed, and copy ``src`` into ``asset_dir`` under a
    normalized ``ref-<n>.<ext>`` filename; return that filename.

    Validation uses `_sniff_mime` (PNG/JPEG/WEBP). Oversized images are shrunk by
    calling `_downsize_reference` DIRECTLY (not `_load_reference`, which is the
    codex-only base64 path). Exits cleanly on a missing file / unsupported type.
    """
    p = Path(src).expanduser()
    if not p.is_file():
        sys.exit(f"reference image not found: {src}")
    raw = p.read_bytes()
    mime = _sniff_mime(raw)
    if mime is None:
        sys.exit(f"unsupported reference image type for {src!r} (need PNG, JPEG, or WEBP)")
    ext = _REF_EXT_BY_MIME.get(mime, "png")
    data = raw
    # Downsize oversized references just like the codex path does — directly via
    # sips, keeping the no-pip-deps property — so the library stays portable.
    if len(base64.b64encode(raw)) > REF_B64_BUDGET:
        shrunk = _downsize_reference(str(p))
        if shrunk is not None:
            data = shrunk
            ext = "jpg"
    fname = f"ref-{_next_ref_index(asset_dir, existing)}.{ext}"
    asset_dir.mkdir(parents=True, exist_ok=True)
    dst = asset_dir / fname
    tmp = dst.with_name(dst.name + ".tmp")
    tmp.write_bytes(data)
    os.replace(tmp, dst)
    return fname


# ---------- self-update reminder ----------

def _update_cache_path() -> Path:
    base = os.environ.get("XDG_CONFIG_HOME", "").strip()
    root = Path(base) if base else Path.home() / ".config"
    return root / "chatgpt-imagegen" / "update-check.json"


def _parse_whatsnew(text: str) -> dict:
    """Map version → one-line note from `# WHATSNEW[ver]: note` comment lines."""
    out: dict[str, str] = {}
    for ver, note in re.findall(r"WHATSNEW\[([\d.]+)\]:\s*(.+)", text):
        out.setdefault(ver, note.strip())
    return out


def _fetch_latest_info(timeout: float = 4.0):
    """Best-effort `(latest_version, {ver: note})` from the script on main.

    Reads only an 8KB prefix (both `__version__` and the WHATSNEW lines live at
    the top), so it never pulls the whole file. Any network/parse failure returns
    `(None, {})` — this is a nicety, never a gate."""
    try:
        req = urllib.request.Request(
            UPDATE_CHECK_URL,
            headers={"User-Agent": f"chatgpt-imagegen/{__version__} update-check"},
        )
        with urllib.request.urlopen(req, timeout=timeout) as r:
            head = r.read(8192).decode("utf-8", "replace")
    except Exception:  # noqa: BLE001
        return None, {}
    m = re.search(r'__version__\s*=\s*"([\d.]+)"', head)
    return (m.group(1) if m else None), _parse_whatsnew(head)


def _changes_since(notes: dict, base: str = __version__) -> list[tuple[str, str]]:
    """WHATSNEW entries strictly newer than ``base``, newest first."""
    cur = _version_tuple(base)
    vers = sorted((v for v in notes if _version_tuple(v) > cur),
                  key=_version_tuple, reverse=True)
    return [(v, notes[v]) for v in vers]


def _format_update_notice(latest: str, notes: dict, max_lines: int = 3) -> str:
    """One header line + up to ``max_lines`` `• ver: what-changed` lines."""
    head = (f"提示:chatgpt-imagegen {latest} 可用(当前 {__version__})。"
            f"更新:skills update chatgpt-imagegen")
    changes = _changes_since(notes)
    lines = [head]
    for ver, note in changes[:max_lines]:
        lines.append(f"  • {ver}:{note}")
    extra = len(changes) - max_lines
    if extra > 0:
        lines.append(f"  • 另有 {extra} 项更新")
    return "\n".join(lines)


def _maybe_notify_update(emit) -> None:
    """Once a day, soft-notify via ``emit`` if a newer version is on main —
    including a terse list of what changed since the installed version.

    Caches the result (timestamp, latest version, and the what's-new notes)
    under the config dir so normal runs do no network at all between daily
    checks. Fully skipped when CHATGPT_IMAGEGEN_NO_UPDATE_CHECK is set. Never
    raises."""
    if os.environ.get("CHATGPT_IMAGEGEN_NO_UPDATE_CHECK"):
        return
    cache = _update_cache_path()
    now = time.time()
    try:
        data = json.loads(cache.read_text(encoding="utf-8"))
        last = float(data.get("checked_at", 0))
        latest = data.get("latest")
        notes = data.get("notes") or {}
    except Exception:  # noqa: BLE001
        last, latest, notes = 0.0, None, {}

    if now - last >= UPDATE_CHECK_INTERVAL:
        fetched_latest, fetched_notes = _fetch_latest_info()
        if fetched_latest:                      # keep last-known if the fetch failed
            latest, notes = fetched_latest, fetched_notes
        try:
            cache.parent.mkdir(parents=True, exist_ok=True)
            cache.write_text(json.dumps(
                {"checked_at": now, "latest": latest, "notes": notes}), encoding="utf-8")
        except Exception:  # noqa: BLE001
            pass

    if latest and _version_tuple(latest) > _version_tuple(__version__):
        emit(_format_update_notice(latest, notes))


def _builtin_styles() -> dict:
    return dict(_BUILTIN_STYLES)


def _default_styles_doc() -> dict:
    # version 2: entries are {kind, snippet, refs} objects and `default` is a
    # list. Built-ins are seeded as bare strings (a legacy shape that
    # `_normalize_doc` upgrades on load) so the on-disk seed stays minimal.
    return {"version": 2, "default": [], "styles": _builtin_styles()}


def _normalize_entry(value: Any) -> dict:
    """Coerce one styles entry into the v2 object shape {kind, snippet, refs}.

    A legacy bare string → {kind: "style", snippet: <str>, refs: []}. An object
    is sanitized: kind clamped to the allowed set, snippet to a str, refs to a
    list of strings.
    """
    if isinstance(value, str):
        return {"kind": "style", "snippet": value, "refs": []}
    if isinstance(value, dict):
        kind = value.get("kind")
        if kind not in _STYLE_KINDS:
            kind = "style"
        snippet = value.get("snippet")
        if not isinstance(snippet, str):
            snippet = ""
        refs = value.get("refs")
        refs = [r for r in refs if isinstance(r, str)] if isinstance(refs, list) else []
        return {"kind": kind, "snippet": snippet, "refs": refs}
    return {"kind": "style", "snippet": "", "refs": []}


def _normalize_doc(doc: dict) -> dict:
    """In-place upgrade a styles doc to version 2 so ALL downstream code sees
    objects + a list `default`.

    Centralizing this is what lets the generation hot path, `style list`, and
    `style show` stop assuming the value is a bare string. Mutating commands
    rewrite the upgraded shape; plain reads don't (no destructive auto-migration).
    """
    styles = doc.get("styles")
    if isinstance(styles, dict):
        for name, value in list(styles.items()):
            styles[name] = _normalize_entry(value)
    default = doc.get("default")
    if isinstance(default, str):
        doc["default"] = [default] if default else []
    elif isinstance(default, list):
        doc["default"] = [d for d in default if isinstance(d, str)]
    else:
        doc["default"] = []
    doc["version"] = 2
    return doc


def _save_styles(doc: dict) -> None:
    """Atomically write the styles doc (temp file + os.replace)."""
    path = _styles_path()
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(path.name + ".tmp")
    tmp.write_text(json.dumps(doc, ensure_ascii=False, indent=2) + "\n",
                   encoding="utf-8")
    os.replace(tmp, path)


def _load_styles() -> dict:
    """Read the styles doc, seeding built-ins on first use. Raises SystemExit
    (clear message) on a corrupt/unreadable file rather than clobbering it."""
    path = _styles_path()
    if not path.exists():
        doc = _default_styles_doc()
        _save_styles(doc)            # seed the minimal (legacy-shaped) built-ins
        return _normalize_doc(doc)   # but hand callers the normalized v2 shape
    try:
        doc = json.loads(path.read_text(encoding="utf-8"))
    except (ValueError, OSError) as e:
        raise SystemExit(f"error: cannot read styles file {path}: {e}")
    if not isinstance(doc, dict) or not isinstance(doc.get("styles"), dict):
        raise SystemExit(
            f"error: malformed styles file {path} "
            f"(expected an object with a 'styles' map). "
            f"Fix it by hand or run `chatgpt-imagegen style reset`.")
    # Normalize immediately so every downstream site sees v2 objects + a list
    # `default` — legacy bare-string entries and a string `default` included.
    return _normalize_doc(doc)


def _die_unknown_style(name: str, styles: dict) -> None:
    avail = ", ".join(sorted(styles)) or "(none)"
    raise SystemExit(f"error: unknown style {name!r}. available: {avail}")


def _resolve_style_name(doc: dict, *, style_arg: str | None,
                        no_style: bool) -> str | None:
    """Pick the style NAME to apply (or None). Order:
    1. --no-style       → None
    2. --style NAME     → NAME (error if unknown)
    3. active default   → it
    4. otherwise        → None
    """
    if no_style:
        return None
    styles = doc.get("styles", {})
    name = style_arg or (doc.get("default") or "")
    if not name:
        return None
    if name not in styles:
        _die_unknown_style(name, styles)
    return name


def _resolve_active_styles(doc: dict, *, style_args: list[str] | None,
                           no_style: bool) -> list[str]:
    """The active asset set (ordered) for a run. Stacking-aware successor to
    `_resolve_style_name`:

    1. --no-style          → []  (disables all asset application)
    2. explicit --style …  → those names, in order
    3. else                → the saved `default` list, in order

    Unknown names raise SystemExit (reusing `_die_unknown_style`).
    """
    if no_style:
        return []
    styles = doc.get("styles", {})
    names = list(style_args) if style_args else list(doc.get("default") or [])
    for n in names:
        if n not in styles:
            _die_unknown_style(n, styles)
    return names


def _collect_refs(doc: dict, active_names: list[str],
                  adhoc_refs: list[str] | None) -> list[dict]:
    """Build the ordered reference list for a run.

    Each item is ``{ref, group, label}`` where ``ref`` is a path/URL to attach,
    ``group`` is "character" or "style", and ``label`` names it for logging.
    Ordering (deterministic): character group first, then style group. Within
    the character group: character assets in active order, then the ad-hoc
    ``--ref`` images last (treated as character/subject, preserving the old
    is_edit behavior). Within the style group: active order.

    Asset reference files must exist on disk — a missing one exits with an error
    naming the asset and the expected path (never silently skipped).
    """
    styles = doc.get("styles", {})
    char_items: list[dict] = []
    style_items: list[dict] = []
    for name in active_names:
        entry = styles[name]
        group = "character" if entry.get("kind") == "character" else "style"
        adir = _asset_dir(name)
        for fn in (entry.get("refs") or []):
            fpath = adir / fn
            if not fpath.is_file():
                raise SystemExit(
                    f"error: asset {name!r} references {fn!r} but the file is "
                    f"missing: {fpath}. Re-pin it (`chatgpt-imagegen style "
                    f"add-ref {name} <img>`) or drop it "
                    f"(`chatgpt-imagegen style rm-ref {name} {fn}`).")
            rec = {"ref": str(fpath), "group": group, "label": f"{name}/{fn}"}
            (char_items if group == "character" else style_items).append(rec)
    for r in (adhoc_refs or []):
        char_items.append({"ref": r, "group": "character", "label": r})
    return char_items + style_items


def _cap_refs(ordered: list[dict], cap: int) -> tuple[list[dict], list[dict]]:
    """Split an ordered ref list at ``cap`` → (kept, dropped). cap<=0 disables."""
    if cap and len(ordered) > cap:
        return ordered[:cap], ordered[cap:]
    return list(ordered), []


def _style_command(argv: list[str]) -> int:
    """`chatgpt-imagegen style <verb> ...` — manage style presets."""
    p = argparse.ArgumentParser(
        prog="chatgpt-imagegen style",
        description="Manage reusable prompt-style presets "
                    f"(stored in {_styles_path()}).")
    sub = p.add_subparsers(dest="verb")
    sub.add_parser("list", help="list all assets (kind, 📎ref count, active *)")
    sp = sub.add_parser("show", help="print one asset's kind, snippet, refs, path")
    sp.add_argument("name")
    sp = sub.add_parser("add", help="create or overwrite an asset (snippet and/or refs)")
    sp.add_argument("name")
    sp.add_argument("snippet", nargs="?", default=None)
    sp.add_argument("--ref", action="append", default=None, metavar="IMG",
                    help="reference image to pin (repeatable); copied into the library")
    sp.add_argument("--kind", choices=list(_STYLE_KINDS), default="style",
                    help="character (reproduce as subject) or style (match aesthetic)")
    sp.add_argument("--from-last", action="store_true",
                    help="pin the most recently generated image as a reference")
    sp = sub.add_parser("add-ref", help="append reference image(s) to an asset")
    sp.add_argument("name")
    sp.add_argument("img", nargs="*")
    sp.add_argument("--from-last", action="store_true",
                    help="pin the most recently generated image")
    sp = sub.add_parser("rm-ref", help="remove one reference image from an asset")
    sp.add_argument("name")
    sp.add_argument("file")
    sp = sub.add_parser("rm", help="delete an asset (entry + its reference images)")
    sp.add_argument("name")
    sp = sub.add_parser("use", help="set the active default asset set (accepts multiple)")
    sp.add_argument("name", nargs="+")
    sub.add_parser("clear", help="empty the active default asset set")
    rp = sub.add_parser("reset", help="re-seed built-ins and wipe the asset library")
    rp.add_argument("-y", "--yes", action="store_true", help="skip the confirmation")
    a = p.parse_args(argv)

    if not a.verb:
        p.print_help()
        return 2

    doc = _load_styles()
    styles = doc["styles"]

    if a.verb == "list":
        if not styles:
            print("(no styles)")
            return 0
        default = doc.get("default") or []
        for name in sorted(styles):
            entry = styles[name]
            preview = " ".join((entry.get("snippet") or "").split())
            if len(preview) > 60:
                preview = preview[:59] + "…"
            nrefs = len(entry.get("refs") or [])
            badge = f" 📎{nrefs}" if nrefs else ""
            mark = "*" if name in default else " "
            print(f"{mark} {name} [{entry.get('kind', 'style')}]{badge}: {preview}")
        if default:
            print(f"\n* = active default ({', '.join(default)})")
        else:
            print("\n(no active default — pass --style NAME to apply one)")
        return 0

    if a.verb == "show":
        if a.name not in styles:
            _die_unknown_style(a.name, styles)
        entry = styles[a.name]
        print(f"kind: {entry.get('kind', 'style')}")
        if entry.get("snippet"):
            print(f"snippet: {entry['snippet']}")
        refs = entry.get("refs") or []
        if refs:
            print(f"refs: {', '.join(refs)}")
        print(f"path: {_asset_dir(a.name)}")
        return 0

    if a.verb == "add":
        if not _valid_style_name(a.name):
            raise SystemExit(
                f"error: invalid style name {a.name!r}; use lowercase letters, "
                f"digits, '-' or '_', starting with a letter or digit.")
        srcs = list(a.ref or [])
        if a.from_last:
            srcs.append(_resolve_from_last())
        snippet = (a.snippet or "").strip()
        if not snippet and not srcs:
            raise SystemExit(
                "error: `style add` needs a snippet and/or at least one "
                "--ref/--from-last image.")
        existed = a.name in styles
        asset_dir = _asset_dir(a.name)
        # Overwrite cleanly: drop any prior reference files for this name so a
        # rebuilt asset never inherits stale refs.
        if asset_dir.exists():
            shutil.rmtree(asset_dir, ignore_errors=True)
        stored: list[str] = []
        for src in srcs:
            stored.append(_copy_ref_into_asset(asset_dir, src, stored))
        styles[a.name] = {"kind": a.kind, "snippet": snippet, "refs": stored}
        _save_styles(doc)
        extra = f" ({len(stored)} ref{'s' if len(stored) != 1 else ''})" if stored else ""
        print(f"{'updated' if existed else 'added'} {a.kind} asset {a.name!r}{extra}",
              file=sys.stderr)
        return 0

    if a.verb == "add-ref":
        if a.name not in styles:
            _die_unknown_style(a.name, styles)
        srcs = list(a.img or [])
        if a.from_last:
            srcs.append(_resolve_from_last())
        if not srcs:
            raise SystemExit(
                "error: `style add-ref` needs at least one image (or --from-last).")
        entry = styles[a.name]
        refs = entry.setdefault("refs", [])
        asset_dir = _asset_dir(a.name)
        added = []
        for src in srcs:
            fn = _copy_ref_into_asset(asset_dir, src, refs)
            refs.append(fn)
            added.append(fn)
        _save_styles(doc)
        print(f"added {len(added)} ref(s) to {a.name!r}: {', '.join(added)}",
              file=sys.stderr)
        return 0

    if a.verb == "rm-ref":
        if a.name not in styles:
            _die_unknown_style(a.name, styles)
        entry = styles[a.name]
        refs = entry.get("refs") or []
        if a.file not in refs:
            avail = ", ".join(refs) or "(none)"
            raise SystemExit(
                f"error: {a.name!r} has no reference {a.file!r}. available: {avail}")
        refs.remove(a.file)
        entry["refs"] = refs
        try:
            (_asset_dir(a.name) / a.file).unlink(missing_ok=True)
        except OSError:
            pass
        _save_styles(doc)
        print(f"removed ref {a.file!r} from {a.name!r}", file=sys.stderr)
        return 0

    if a.verb == "rm":
        if a.name not in styles:
            _die_unknown_style(a.name, styles)
        del styles[a.name]
        shutil.rmtree(_asset_dir(a.name), ignore_errors=True)
        default = doc.get("default") or []
        cleared = a.name in default
        if cleared:
            doc["default"] = [d for d in default if d != a.name]
        _save_styles(doc)
        tail = " (was in the active default; removed from it)" if cleared else ""
        print(f"removed asset {a.name!r}{tail}", file=sys.stderr)
        return 0

    if a.verb == "use":
        for name in a.name:
            if name not in styles:
                _die_unknown_style(name, styles)
        doc["default"] = list(a.name)
        _save_styles(doc)
        print(f"active default set to {', '.join(a.name)}", file=sys.stderr)
        return 0

    if a.verb == "clear":
        doc["default"] = []
        _save_styles(doc)
        print("active default cleared", file=sys.stderr)
        return 0

    if a.verb == "reset":
        if not a.yes:
            sys.stderr.write(
                "This discards all style edits AND deletes every pinned "
                "reference image, restoring built-ins. Continue? [y/N] ")
            sys.stderr.flush()
            if sys.stdin.readline().strip().lower() not in ("y", "yes"):
                print("aborted", file=sys.stderr)
                return 1
        shutil.rmtree(_assets_root(), ignore_errors=True)
        _save_styles(_default_styles_doc())
        print("styles reset to built-ins (asset library wiped)", file=sys.stderr)
        return 0

    return 0


# ---------- doctor (preflight backend check) ----------

def _web_ready(chrome_use_installed: bool, relay: bool, n_profiles: int) -> bool:
    """The web backend can run if chrome-use is installed AND there's a logged-in
    browser to reach — the connected relay (your open Chrome) or at least one
    offline-detected logged-in profile we can launch."""
    return chrome_use_installed and (relay or n_profiles > 0)


def _auto_backend_pick(web_ready: bool, codex_ready: bool) -> str:
    """Which backend `--backend auto` would use, given each one's readiness."""
    if web_ready:
        return "web"
    if codex_ready:
        return "codex"
    return "neither"


_AB_INSTALL_ONELINE = (
    "not installed — curl -fsSL https://raw.githubusercontent.com/leeguooooo/"
    "chrome-use/main/install.sh | sh"
)


def _doctor_command(argv: list[str]) -> int:
    """`chatgpt-imagegen doctor` — preflight check of both backends.

    Reports whether each backend is set up and which one `auto` would pick, so a
    "no logged-in browser" / "no token" failure is diagnosable BEFORE a real run
    (issue #15). Read-only; exits 0 if at least one backend is ready, else 1."""
    color = _use_color(sys.stdout)
    sym = {
        "ok":   _green("✓") if color else "[ok]  ",
        "warn": _yellow("⚠") if color else "[warn]",
        "fail": _red("✗") if color else "[fail]",
    }

    def line(status: str, label: str, detail: str) -> None:
        print(f"  {sym[status]}  {label:<11}{detail}")

    print("chatgpt-imagegen doctor\n")

    pv = f"{sys.version_info.major}.{sys.version_info.minor}.{sys.version_info.micro}"
    ok_py = sys.version_info >= (3, 10)
    line("ok" if ok_py else "fail", "python", pv + ("" if ok_py else "  (need 3.10+)"))

    latest, notes = _fetch_latest_info()  # always fresh here (no throttle)
    if latest and _version_tuple(latest) > _version_tuple(__version__):
        line("warn", "version",
             f"{__version__} → {latest} 可用 (skills update chatgpt-imagegen)")
        for ver, note in _changes_since(notes)[:5]:
            print(f"               • {ver}:{note}")
    else:
        line("ok", "version", __version__ + (" (latest)" if latest else ""))

    codex_ready = _codex_token_present()
    line("ok" if codex_ready else "fail", "codex",
         "OAuth token present (~/.codex/auth.json)" if codex_ready
         else "no token — run `codex login`")

    print("\n  web backend:")
    ab = _find_agent_browser()
    relay = False
    profiles: list[str] = []
    if ab is None:
        line("fail", "chrome-use", _AB_INSTALL_ONELINE)
    else:
        v = _chrome_use_version(ab)
        if v and _version_tuple(v) < _version_tuple(AB_MIN_VERSION):
            line("warn", "chrome-use",
                 f"{v} < {AB_MIN_VERSION} — update it (img2img/model-switch may fail)")
        else:
            line("ok", "chrome-use", v or "installed")
        relay = _relay_connected(ab)
        line("ok" if relay else "fail", "relay",
             "connected (drives your open Chrome)" if relay
             else "not connected — load the ab-connect extension, restart Chrome")
        profiles = _detect_logged_in_profiles()
        if profiles:
            shown = ", ".join(profiles[:4]) + ("…" if len(profiles) > 4 else "")
            line("ok", "profiles", f"{len(profiles)} logged-in: {shown}")
        else:
            line("fail", "profiles", "none detected — sign in to chatgpt.com")

    web_ready = _web_ready(ab is not None, relay, len(profiles))
    pick = _auto_backend_pick(web_ready, codex_ready)
    arrow = _dim("→", stream=sys.stdout) if color else "→"
    print()
    if pick == "neither":
        print(f"  {arrow} auto: no backend ready — set up one of the above.\n")
        return 1
    note = "spares Codex-usage" if pick == "web" else "bills Codex-usage"
    print(f"  {arrow} auto would use: {pick}  ({note})\n")
    return 0


def _open_file(path: Path, progress: bool) -> None:
    """Best-effort: open the saved image in the OS default viewer (`--open`).
    Never fails the run — a failure to launch the viewer only warns."""
    try:
        if sys.platform == "darwin":
            opener: list[str] = ["open", str(path)]
        elif sys.platform.startswith("win"):
            os.startfile(str(path))  # type: ignore[attr-defined]  # noqa: PLW1510
            return
        else:
            opener = ["xdg-open", str(path)]
        subprocess.Popen(opener, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception as e:  # noqa: BLE001
        if progress:
            print(f"warning: could not open {path}: {e}", file=sys.stderr)


# ---------- main ----------

_HELP_EPILOG = """\
examples:
  chatgpt-imagegen "a watercolor cat" -o cat.png
  chatgpt-imagegen "coffee shop logo, vector style" -o logo.png --size 1024x1024
  chatgpt-imagegen "restyle this, golden hour" -i photo.jpg -o out.png   # image-to-image
  chatgpt-imagegen "a settings icon" --style doodle --open
  OUT=$(chatgpt-imagegen "icon" --quiet)                                 # capture the path

subcommands:
  chatgpt-imagegen doctor          check which backend is ready (and which auto picks)
  chatgpt-imagegen style <verb>    manage reusable style/character assets (alias: styles)

docs: https://github.com/leeguooooo/chatgpt-imagegen
"""


def main() -> int:
    if len(sys.argv) > 1 and sys.argv[1] in ("style", "styles"):
        return _style_command(sys.argv[2:])
    if len(sys.argv) > 1 and sys.argv[1] == "doctor":
        return _doctor_command(sys.argv[2:])
    parser = argparse.ArgumentParser(
        description="Generate an image with your ChatGPT subscription (no API key).",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=_HELP_EPILOG,
    )
    parser.add_argument(
        "-V", "--version", action="version",
        version=f"chatgpt-imagegen {__version__}",
    )
    parser.add_argument("prompt", help="Description of the image to generate")
    style_grp = parser.add_mutually_exclusive_group()
    style_grp.add_argument(
        "--style", action="append", default=None, metavar="NAME",
        help="Apply a saved asset (style or character) to this prompt — its text "
             "snippet and any pinned reference images (see `chatgpt-imagegen "
             "style list`). Repeatable: multiple assets stack. Overrides the "
             "active default set for this run.",
    )
    style_grp.add_argument(
        "--no-style", action="store_true",
        help="Skip all assets (text + refs) for this run even if a default set "
             "is configured.",
    )
    parser.add_argument("-o", "--out", help="Output file path (default: assets/generated/<slug>.<ext>)")
    parser.add_argument(
        "--size",
        default="auto",
        help="auto | WIDTHxHEIGHT (e.g. 1024x1024, 1536x1024, 1024x1536). "
             "Forwarded as-is; the backend decides what it accepts.",
    )
    parser.add_argument("--format", default="png", choices=["png", "jpeg", "webp"])
    parser.add_argument("--model", default=os.environ.get("CHATGPT_IMAGEGEN_MODEL", "gpt-5.5"))
    parser.add_argument(
        "-i", "--ref",
        action="append",
        default=None,
        metavar="PATH_OR_URL",
        help="Reference image for image-to-image (repeatable). A local path or "
             "http(s) URL. When given, generation edits the reference(s) instead "
             "of rendering from text. Works on both backends: web attaches it to "
             "the composer (no Codex-usage), codex sends it as an input_image.",
    )
    parser.add_argument(
        "--backend",
        choices=["auto", "web", "codex"],
        default=os.environ.get("CHATGPT_IMAGEGEN_BACKEND", "auto"),
        help="auto (default): prefer web (spares Codex-usage limits); fall back "
             "to codex only if the browser isn't available/logged in. "
             "web: force the logged-in-browser path (chrome-use). "
             "codex: force the headless codex/responses path (bills Codex-usage). "
             "Also settable via CHATGPT_IMAGEGEN_BACKEND.",
    )
    parser.add_argument(
        "--session",
        default=None,
        help="(web backend) chrome-use session name to reuse a Chrome tab "
             "group across runs (default: imagegen-<pid>).",
    )
    parser.add_argument(
        "--project",
        default=os.environ.get("CHATGPT_IMAGEGEN_PROJECT", DEFAULT_PROJECT),
        help="(web backend) ChatGPT Project to file the conversation under — "
             f"found by exact name, created if absent (default: {DEFAULT_PROJECT!r}; "
             "also settable via CHATGPT_IMAGEGEN_PROJECT). Pass an empty string "
             "to use a plain top-level chat instead.",
    )
    parser.add_argument(
        "--web-model",
        default=os.environ.get("CHATGPT_IMAGEGEN_WEB_MODEL", WEB_MODEL_DEFAULT),
        help="(web backend) composer model/effort to select before generating — "
             "a comma-separated candidate list, first one present in the picker "
             f"wins (default: {WEB_MODEL_DEFAULT!r}; also settable via "
             "CHATGPT_IMAGEGEN_WEB_MODEL). Labels must match the picker exactly. "
             "The 'Pro' tier has no native image generator, so leaving it on Pro "
             "makes the page write Python instead of an image — hence the switch. "
             "Pass an empty string to keep whatever model is already selected.",
    )
    parser.add_argument(
        "--profile",
        default="auto",
        help="(web backend) which Chrome profile to drive. auto (default): "
             "offline-detect a profile that's logged in to chatgpt.com and use "
             "the freshest; relay: use your currently-open Chrome via the "
             "extension; or a profile name like \"Profile 3\".",
    )
    parser.add_argument(
        "--keep-tab",
        action="store_true",
        help="(web backend) leave the ChatGPT tab open after generating instead "
             "of closing it. Implies --keep-conversation (an open tab on a "
             "deleted chat is useless).",
    )
    parser.add_argument(
        "--keep-conversation",
        action="store_true",
        default=_env_bool("CHATGPT_IMAGEGEN_KEEP_CONVERSATION"),
        help="(web backend) keep the ChatGPT conversation after generating. "
             "Default: the conversation is DELETED so the run leaves no history "
             "(it's filed under the project only transiently). Also settable via "
             "CHATGPT_IMAGEGEN_KEEP_CONVERSATION=1.",
    )
    parser.add_argument(
        "--timeout",
        type=_positive_int,
        default=DEFAULT_TOTAL_TIMEOUT,
        help=f"Total wall-clock budget for the request, in seconds "
             f"(default: {DEFAULT_TOTAL_TIMEOUT}). Large images can take 2-3 min.",
    )
    parser.add_argument(
        "--stall-timeout",
        type=_positive_int,
        default=int(DEFAULT_STALL_TIMEOUT),
        help=f"Max seconds of silence (no SSE data) before the request is "
             f"declared stalled (default: {int(DEFAULT_STALL_TIMEOUT)}). "
             f"Clamped to --timeout.",
    )
    parser.add_argument(
        "--quiet",
        action="store_true",
        help="Print only the saved path on stdout (stderr progress is unaffected; "
             "use --no-progress to silence it).",
    )
    parser.add_argument(
        "--no-progress",
        action="store_true",
        help="Suppress the stderr progress timeline (errors are still shown).",
    )
    parser.add_argument(
        "--open",
        dest="open_after",
        action="store_true",
        help="Open the saved image in the OS default viewer after generating "
             "(macOS `open`, Linux `xdg-open`, Windows default). Best-effort.",
    )
    args = parser.parse_args()
    progress = not args.no_progress
    _styles_doc = _load_styles()
    # Resolve the active asset set (stacking-aware), fold each asset's snippet
    # into the prompt, then partition the assets' reference images into
    # character/style groups in deterministic order.
    _active = _resolve_active_styles(
        _styles_doc, style_args=args.style, no_style=args.no_style)
    _gen_prompt = args.prompt
    for _name in _active:
        _gen_prompt = _compose_prompt(
            _gen_prompt, _styles_doc["styles"][_name].get("snippet"))
    args.gen_prompt = _gen_prompt

    _ordered_refs = _collect_refs(_styles_doc, _active, args.ref)
    _kept_refs, _dropped_refs = _cap_refs(_ordered_refs, REF_ATTACH_CAP)
    args.resolved_refs = [r["ref"] for r in _kept_refs]
    args.n_character_refs = sum(1 for r in _kept_refs if r["group"] == "character")
    args.n_style_refs = sum(1 for r in _kept_refs if r["group"] == "style")

    stall_timeout = float(min(args.stall_timeout, args.timeout))
    start = time.monotonic()

    # Over-cap drops are a data-affecting event, not progress chatter: the spec
    # requires we "never silently truncate" and log exactly which refs were
    # dropped. Emit unconditionally to stderr so scripted/`--no-progress`
    # callers still see it (errors/warnings survive `--no-progress`).
    if _dropped_refs:
        names = ", ".join(r["label"] for r in _dropped_refs)
        print(_fmt_progress(
            0.0,
            f"warning: more than {REF_ATTACH_CAP} reference images resolved; "
            f"attaching the first {REF_ATTACH_CAP} (character-first), dropped: "
            f"{names}"), file=sys.stderr)

    # One-line, once-a-day update nudge. Stderr only (stdout stays exactly the
    # saved path), and skipped under --quiet/--no-progress so machine callers
    # stay clean. `doctor` checks unconditionally for a deliberate look.
    if progress and not args.quiet:
        _maybe_notify_update(lambda m: print(_yellow(m), file=sys.stderr))

    if progress:
        prompt_preview = f"{args.prompt[:60]}{'…' if len(args.prompt) > 60 else ''}"
        meta_bit = _dim(f"(backend={args.backend} size={args.size} "
                        f"format={args.format} timeout={args.timeout}s)")
        print(_fmt_progress(0.0, f"requesting image  {meta_bit}"), file=sys.stderr)
        print(_dim(f"           prompt: {prompt_preview}"), file=sys.stderr)
        if _active:
            print(_dim(f"           styles: {', '.join(_active)}"), file=sys.stderr)

    image_bytes, meta = _dispatch(args, progress, stall_timeout, start)

    out_path = Path(args.out) if args.out else _default_out_path(args.prompt, args.format)
    if args.out and progress:
        _maybe_warn_extension_mismatch(out_path, args.format)
    out_path.parent.mkdir(parents=True, exist_ok=True)
    out_path.write_bytes(image_bytes)
    # Record this image so `style add --from-last` / `add-ref --from-last` can
    # pin it. The `style` subcommand returns early above, so it never records.
    _record_last_output(out_path)

    if progress:
        size_info = f"  size={meta.get('size')}" if meta.get("size") else ""
        quality_info = f"  quality={meta.get('quality')}" if meta.get("quality") else ""
        print(
            _fmt_progress(
                time.monotonic() - start,
                _green(f"✓ saved → {out_path}")
                + _dim(f"  ({len(image_bytes):,} bytes){size_info}{quality_info}"),
            ),
            file=sys.stderr,
        )
    if getattr(args, "open_after", False):
        _open_file(out_path, progress)
    # stdout is always exactly the saved path, one line — safe for `$(...)` capture.
    print(out_path)
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        sys.exit(130)
