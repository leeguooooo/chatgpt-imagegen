CODEX_BACKEND = "https://chatgpt.com/backend-api/codex/responses"
# Default idle gap (seconds) tolerated between SSE chunks before the stream is
# treated as stalled. The connect timeout urllib applies to urlopen() also
# governs every subsequent read, so without loosening it a >connect-timeout
# pause mid-stream (common while a detailed image renders) kills a live stream.
# Overridable via --stall-timeout; always clamped to the total --timeout.
# Measured: a real "generating" phase can stay silent ~66s before the first
# partial image, so 120s leaves margin against false stalls on the slowest
# images while still catching a genuine hang well inside the total budget.
DEFAULT_STALL_TIMEOUT = 120.0
DEFAULT_TOTAL_TIMEOUT = 300  # large images occasionally take 2-3 minutes
OAUTH_TOKEN_URL = "https://auth.openai.com/oauth/token"
OAUTH_CLIENT_ID = "app_EMoamEEZ73f0CkXaXp7hrann"  # Codex CLI's published client id
FALLBACK_VERSION = "0.130.0"
FALLBACK_UA = f"codex_cli_rs/{FALLBACK_VERSION} (Mac OS 26.0.1; arm64) chatgpt-imagegen"
AUTH_PATH = Path.home() / ".codex" / "auth.json"
VERSION_PATH = Path.home() / ".codex" / "version.json"

# Web backend: drive the real, logged-in ChatGPT browser via agent-browser-stealth
# so image generation runs on the ChatGPT *conversation* surface (the cheap bucket)
# rather than the codex/responses surface (the metered Codex-usage bucket). The
# stealth fork's real-Chrome connect clears Cloudflare + the sentinel proof-of-work
# that a plain/headless client cannot replicate. See README "Backends".
# The stealth package ships one binary exposed under three command names — accept
# whichever is on PATH (on a typical install the latter two symlink to the first).
AB_BIN_CANDIDATES = ("agent-browser", "agent-browser-stealth", "abs")
# A *regular* new chat — NOT a temporary chat. Temporary Chat disables the
# image_generation tool ("I can't generate images in this temporary chat"),
# so we must use a normal conversation. Trade-off: each run leaves a chat in
# history. Pass --keep-tab to inspect it; delete from the UI if you want.
WEB_NEW_CHAT_URL = "https://chatgpt.com/"
# Image assets render as <img> whose src points at one of these backend paths.
WEB_IMG_SRC_RE = r"estuary/content|files/download|oaiusercontent"

JsonDict = dict[str, Any]


class GatewayError(RuntimeError):
    """Raised when the upstream HTTP call fails. Carries the status code."""

    def __init__(self, message: str, status: int | None = None) -> None:
        super().__init__(message)
        self.status = status


class WebUnavailable(GatewayError):
    """The web backend can't run at all (agent-browser missing, browser not
    reachable, or chatgpt.com not logged in) — as opposed to a failure that
    happens *after* a prompt was successfully submitted.

    Auto-routing treats this as "fall back to codex"; a failure after submit is
    a plain GatewayError and must NOT silently fall back (that would burn the
    Codex-usage bucket the web backend exists to spare)."""


# ---------- auth ----------

def _load_auth() -> JsonDict:
    if not AUTH_PATH.exists():
        sys.exit(
            f"~/.codex/auth.json not found.\n"
            f"Install Codex CLI (`npm i -g @openai/codex`) and run `codex login` first."
        )
    try:
        return json.loads(AUTH_PATH.read_text(encoding="utf-8"))
    except Exception as e:
        sys.exit(f"failed to parse {AUTH_PATH}: {e}")


def _extract_access_token(auth: JsonDict) -> tuple[str | None, str | None, str | None]:
    """Return (access_token, account_id, refresh_token).

    Only honours the OAuth `tokens` block written by `codex login`. An older
    `OPENAI_API_KEY` field is intentionally NOT used as a fallback — that field
    is an API key, not a ChatGPT OAuth bearer, and the backend rejects it.
    """
    tokens = auth.get("tokens")
    if not isinstance(tokens, dict):
        return None, None, None
    access = tokens.get("access_token") if isinstance(tokens.get("access_token"), str) else None
    account_id = tokens.get("account_id") if isinstance(tokens.get("account_id"), str) else None
    refresh = tokens.get("refresh_token") if isinstance(tokens.get("refresh_token"), str) else None
    return access, account_id, refresh


def _refresh_access_token(refresh_token: str, timeout: int = 30) -> JsonDict:
    data = urllib.parse.urlencode(
        {
            "client_id": OAUTH_CLIENT_ID,
            "grant_type": "refresh_token",
            "refresh_token": refresh_token,
            "scope": "openid profile email",
        }
    ).encode("utf-8")
    req = urllib.request.Request(
        OAUTH_TOKEN_URL,
        data=data,
        headers={
            "Accept": "application/json",
            "Content-Type": "application/x-www-form-urlencoded",
            "User-Agent": FALLBACK_UA,
        },
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return json.loads(resp.read().decode("utf-8"))
    except urllib.error.HTTPError as e:
        body = e.read().decode("utf-8", errors="ignore")
        # Try to surface the OAuth `error` field without leaking the full body.
        oauth_err = ""
        try:
            parsed = json.loads(body)
            if isinstance(parsed, dict) and isinstance(parsed.get("error"), str):
                oauth_err = parsed["error"]
        except Exception:
            pass
        if oauth_err == "invalid_grant":
            raise GatewayError(
                "refresh_token is no longer valid — run `codex login` again to re-authenticate.",
                status=e.code,
            ) from None
        # Avoid leaking the full response body. Surface only HTTP status and error code.
        msg = f"token refresh failed: HTTP {e.code}"
        if oauth_err:
            msg += f" ({oauth_err})"
        raise GatewayError(msg, status=e.code) from None


def _persist_refreshed_auth(original: JsonDict, refreshed: JsonDict) -> None:
    """Atomically rewrite ~/.codex/auth.json with the refreshed tokens.

    Writes a temp file in the same directory with mode 0600, fsyncs it, then
    os.replace()s it over the original. Survives crashes / disk-full midwrite.
    """
    tokens = original.get("tokens")
    if not isinstance(tokens, dict):
        tokens = {}
        original["tokens"] = tokens
    if isinstance(refreshed.get("access_token"), str):
        tokens["access_token"] = refreshed["access_token"]
    if isinstance(refreshed.get("refresh_token"), str):
        tokens["refresh_token"] = refreshed["refresh_token"]
    if isinstance(refreshed.get("id_token"), str):
        tokens["id_token"] = refreshed["id_token"]
    original["last_refresh"] = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())

    serialized = json.dumps(original, indent=2).encode("utf-8")
    AUTH_PATH.parent.mkdir(parents=True, exist_ok=True)
    fd, tmp_path = tempfile.mkstemp(prefix=".auth.", suffix=".tmp", dir=str(AUTH_PATH.parent))
    tmp_file = Path(tmp_path)
    try:
        os.fchmod(fd, 0o600)
        with os.fdopen(fd, "wb") as fh:
            fh.write(serialized)
            fh.flush()
            os.fsync(fh.fileno())
        os.replace(tmp_path, AUTH_PATH)
    except Exception:
        try:
            tmp_file.unlink(missing_ok=True)
        except Exception:
            pass
        raise


def _detect_codex_version() -> str:
    """Best codex version string to send in the `version` header.

    Reads `~/.codex/version.json`, but returns the *newer* of that value and
    FALLBACK_VERSION. A stale `latest_version` (seen in the wild as low as
    0.99.0 while the installed CLI was 0.130.0) makes the backend reject newer
    models with "requires a newer version of Codex" — so never send a version
    older than our known-good floor.
    """
    def parse(v: str) -> tuple[int, int, int] | None:
        return tuple(int(p) for p in v.split(".")) if re.fullmatch(r"\d+\.\d+\.\d+", v) else None  # type: ignore[return-value]

    floor = FALLBACK_VERSION
    try:
        if VERSION_PATH.exists():
            data = json.loads(VERSION_PATH.read_text(encoding="utf-8"))
            v = data.get("latest_version")
            if isinstance(v, str):
                pv, pf = parse(v), parse(floor)
                if pv and pf:
                    return v if pv >= pf else floor
                if pv:
                    return v
    except Exception:
        pass
    return floor


def _loosen_read_timeout(resp: Any, timeout: float) -> None:
    """Raise the per-read socket timeout on an already-connected response.

    urlopen()'s ``timeout`` is a *connect* budget, but urllib leaves it on the
    socket so it silently becomes the per-read timeout too. Left at the short
    connect value, a single quiet gap in the SSE stream aborts a generation
    that is still alive. Best-effort: if the socket isn't reachable through the
    documented attribute chain, the connect timeout stays in place.
    """
    try:
        resp.fp.raw._sock.settimeout(timeout)  # type: ignore[attr-defined]
    except Exception:
        pass


def _build_headers(token: str, account_id: str | None, version: str) -> dict[str, str]:
    sid = str(uuid.uuid4())
    headers = {
        "Content-Type": "application/json",
        "Authorization": f"Bearer {token}",
        "Accept": "text/event-stream",
        "Connection": "Keep-Alive",
        "version": version,
        "session_id": sid,
        "x-client-request-id": sid,
        "User-Agent": f"codex_cli_rs/{version} (Mac OS 26.0.1; arm64) chatgpt-imagegen",
        "originator": "codex_cli_rs",
    }
    if account_id:
        headers["chatgpt-account-id"] = account_id
    return headers


# ---------- request ----------

def _build_user_text(prompt: str, size: str, output_format: str) -> str:
    """Natural-language instruction shared by both backends.

    The web UI has no explicit size/format knobs, so we fold those hints into
    the prompt exactly the way the codex tool description does — the model
    reads them and picks the matching aspect ratio.
    """
    user_text = (
        "Use the image_generation tool to render the following. "
        f"Request: {prompt}. "
        f"Output format: {output_format}."
    )
    if size and size != "auto":
        user_text += f" Size: {size}."
    user_text += " Do not include explanatory text — produce only the image."
    return user_text


def _build_payload(prompt: str, size: str, output_format: str, model: str) -> JsonDict:
    user_text = _build_user_text(prompt, size, output_format)

    image_tool: JsonDict = {"type": "image_generation", "output_format": output_format}
    if size and size != "auto":
        image_tool["size"] = size

    # The Codex backend requires `instructions` to match an allowlisted prompt.
    # We use a tiny system-style instruction known to be accepted on gpt-5.5.
    return {
        "model": model,
        "stream": True,
        "instructions": "You are an image generation assistant.",
        "input": [
            {
                "type": "message",
                "role": "user",
                "content": [{"type": "input_text", "text": user_text}],
            }
        ],
        "tools": [image_tool],
        "tool_choice": "auto",
        "parallel_tool_calls": False,
        "store": False,
        "reasoning": {"effort": "low", "summary": "auto"},
        "include": ["reasoning.encrypted_content"],
        "text": {"verbosity": "low"},
    }


def _stream(
    url: str,
    headers: dict[str, str],
    body: JsonDict,
    deadline: float,
    stall_timeout: float,
) -> Iterator[JsonDict]:
    """Yield parsed JSON event dicts from the SSE stream.

    Standards-compliant enough for OpenAI's variant:
      * `:` lines are comments (ignored).
      * `event:` lines are tracked but unused here.
      * `data:` lines accumulate into a single payload per event; blank line
        terminates the event and we yield the parsed JSON.
      * A `data: [DONE]` payload terminates the stream cleanly.
      * Total wall-clock budget is enforced via `deadline` (monotonic time).
    """
    req = urllib.request.Request(
        url,
        data=json.dumps(body).encode("utf-8"),
        headers=headers,
        method="POST",
    )
    # Initial connect timeout: shorter of remaining budget or 30s.
    initial = max(1.0, min(30.0, deadline - time.monotonic()))
    resp = urllib.request.urlopen(req, timeout=initial)
    # Loosen the per-read timeout: a quiet gap between SSE chunks routinely
    # exceeds the 30s connect timeout, and the overall wall-clock cap is already
    # enforced by the `deadline` check below — so bound the per-read idle window
    # by stall_timeout (and never beyond the remaining budget). A read that
    # blocks longer than this raises TimeoutError, which the caller turns into a
    # clean "stalled" message.
    _loosen_read_timeout(resp, min(stall_timeout, max(1.0, deadline - time.monotonic())))
    try:
        data_buf: list[str] = []
        for raw in resp:
            if time.monotonic() >= deadline:
                raise GatewayError(
                    f"stream exceeded total timeout budget; aborting",
                    status=None,
                )
            line = raw.decode("utf-8", errors="ignore").rstrip("\r\n")
            if line == "":
                # End of event.
                if not data_buf:
                    continue
                payload = "\n".join(data_buf)
                data_buf = []
                if payload == "[DONE]":
                    return
                try:
                    yield json.loads(payload)
                except Exception:
                    # Malformed event; keep going but make it visible in verbose mode.
                    print(
                        f"   .. warning: skipped malformed SSE payload "
                        f"({len(payload)} bytes)",
                        file=sys.stderr,
                    )
                continue
            if line.startswith(":"):
                continue  # comment / keepalive
            if line.startswith("event:"):
                continue  # event type — we infer from payload's "type" field
            if line.startswith("data:"):
                # Strip the "data:" prefix and exactly one optional leading space.
                chunk = line[len("data:") :]
                if chunk.startswith(" "):
                    chunk = chunk[1:]
                data_buf.append(chunk)
                continue
            # Other field types (id:, retry:, etc.) — ignore silently.
    finally:
        resp.close()


def _post_for_image(
    payload: JsonDict,
    headers: dict[str, str],
    deadline: float,
    start: float,
    stall_timeout: float,
    progress: bool,
) -> tuple[bytes, JsonDict]:
    """Returns (image_bytes, item_meta). Raises GatewayError on failure.

    When `progress` is set, a human-readable timeline is streamed to stderr —
    one line per phase, each stamped with elapsed seconds — so a slow run is
    legible and a stall is obvious. stdout is never touched here.
    """
    saw_event_types: dict[str, int] = {}
    image_b64: str | None = None
    item_meta: JsonDict = {}
    last_revised_prompt: str = ""
    last_phase = "connecting"

    def emit(msg: str) -> None:
        if progress:
            print(f"[{time.monotonic() - start:6.1f}s] {msg}", file=sys.stderr)

    try:
        for evt in _stream(CODEX_BACKEND, headers, payload, deadline, stall_timeout):
            t = evt.get("type", "?")
            saw_event_types[t] = saw_event_types.get(t, 0) + 1
            first = saw_event_types[t] == 1
            if t == "response.image_generation_call.in_progress" and first:
                last_phase = "queued"
                emit("queued")
            elif t == "response.image_generation_call.generating" and first:
                last_phase = "generating"
                emit("generating")
            elif t == "response.image_generation_call.partial_image":
                last_phase = "receiving image"
                emit(f"receiving image (partial {saw_event_types[t]})")
            if t == "response.output_item.done":
                item = evt.get("item")
                if isinstance(item, dict) and item.get("type") == "image_generation_call":
                    if isinstance(item.get("result"), str):
                        image_b64 = item["result"]
                        item_meta = {k: v for k, v in item.items() if k != "result"}
                        if isinstance(item.get("revised_prompt"), str):
                            last_revised_prompt = item["revised_prompt"]
    except urllib.error.HTTPError as e:
        body_text = e.read().decode("utf-8", errors="ignore")
        raise GatewayError(f"HTTP {e.code}: {body_text[:600]}", status=e.code) from None
    except (TimeoutError, ConnectionError):
        # Socket read timed out or the connection dropped mid-stream. Surface a
        # clean, actionable message — naming the phase we stalled in and how long
        # we waited — instead of a raw Python traceback.
        elapsed = time.monotonic() - start
        if time.monotonic() >= deadline:
            total = int(round(deadline - start))
            raise GatewayError(
                f"timed out: no image within the {total}s total budget "
                f"(last phase: {last_phase}, {elapsed:.0f}s elapsed). "
                f"Raise --timeout for very large images."
            ) from None
        raise GatewayError(
            f"stalled: the image backend sent no data for ~{int(stall_timeout)}s "
            f"(last phase: {last_phase}, {elapsed:.0f}s elapsed). It may be "
            f"overloaded — retry, or raise --stall-timeout / --timeout."
        ) from None
    except urllib.error.URLError as e:
        raise GatewayError(f"network error contacting the image backend: {e.reason}") from None

    if not image_b64:
        types_seen = ", ".join(sorted(saw_event_types)) or "(none)"
        raise GatewayError(f"no image returned. events seen: {types_seen}")

    if last_revised_prompt:
        emit(f"revised prompt: {last_revised_prompt[:120]}")

    try:
        image_bytes = base64.b64decode(image_b64, validate=True)
    except Exception:
        raise GatewayError("backend returned invalid base64 in image_generation_call.result") from None
    return image_bytes, item_meta


